---
import Base from '../../layouts/Base.astro';
import ShareBar from '../../components/ShareBar.astro';
import { GUIDES, type GuideArticle } from '../../data/guides.ts';
import lastmodJson from '../../data/sitemap-lastmod.json';
const lastmod: Record<string, string> = lastmodJson;

export function getStaticPaths() {
  return GUIDES.map((g) => ({ params: { slug: g.slug }, props: { g } }));
}
interface Props {
  g: GuideArticle;
}
const { g } = Astro.props;
const url = `https://numpredo.com/guide/${g.slug}/`;

// 攻略長文 → Article（著者/発行者で E-E-A-T、dateModified で鮮度。日付は既存の git 提交日を流用、捏造しない）
const dateModified = lastmod[`/guide/${g.slug}/`];
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: g.h1,
  description: g.description,
  inLanguage: 'ja',
  mainEntityOfPage: url,
  image: 'https://numpredo.com/og-image.png',
  author: { '@type': 'Organization', name: 'numpredo', url: 'https://numpredo.com/' },
  publisher: { '@type': 'Organization', name: 'numpredo', logo: { '@type': 'ImageObject', url: 'https://numpredo.com/og-image.png' } },
  ...(dateModified ? { dateModified } : {}),
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: g.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '解き方', item: 'https://numpredo.com/guide/how-to-solve/' },
    { '@type': 'ListItem', position: 3, name: g.h1, item: url },
  ],
};
---

<Base title={g.title} description={g.description} canonical={url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › <a href="/guide/how-to-solve/">解き方</a> › {g.h1}</nav>
  <h1>{g.h1}</h1>
  <p class="lead">{g.lead}</p>

  {g.sections.map((s) => (<><h2>{s.h}</h2>{s.body.map((p) => <p set:html={p} />)}</>))}

  <h2>解き方ガイドに戻る</h2>
  <ul>
    <li><a href="/guide/how-to-solve/">解き方完全ガイド</a></li>
    <li><a href="/play/advanced/">上級をプレイして練習</a></li>
  </ul>

  <ShareBar url={url} title={g.title} cta="この解説が役に立ったらシェア" />

  <h2>よくある質問</h2>
  <dl class="faq">{g.faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

  <style is:global>
    .crumb { font-size: 12px; color: var(--sub); margin-bottom: 10px; } .crumb a { color: var(--sub); text-decoration: none; }
    .lead { color: var(--sub); font-size: 14px; margin: 0 0 16px; }
    main ul { line-height: 2; } main ul a { color: var(--ai); }
    .faq dt { font-family: var(--min); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--sub); }
  </style>
</Base>
