---
import Base from '../../layouts/Base.astro';
import ShareBar from '../../components/ShareBar.astro';
import advanced from '../../data/puzzles/advanced.json';
import { renderBoardSvg, gridFromString, traceFirstElimination, TECH_INFO, TOKEN_THEME, type CandidateMark } from '../../engine/index.ts';
import { TECHNIQUES } from '../../data/techniques.ts';
import lastmodJson from '../../data/sitemap-lastmod.json';
import publishedJson from '../../data/published.json';
const lastmod: Record<string, string> = lastmodJson;
const published: Record<string, string> = publishedJson;

const title = 'ナンプレの解き方｜数独を図解で徹底解説 - numpredo';
const description = 'ナンプレの解き方を図解でやさしく解説。裸の単数・隠れた単数から、区画の絞り込み・ペア（二国同盟）・X-Wingまで、初心者から難問まで使える数独の解法を順番に紹介。例題つきで、論理だけで解く考え方が身につきます。';
const url = 'https://numpredo.com/guide/how-to-solve/';

// 构建期用引擎生成「題面」与「テクニック消去」の和風図解
const sample = gridFromString(advanced.puzzles[0].puzzle);
const givenMask = sample.map((v) => v !== 0);
const svgPuzzle = renderBoardSvg(sample, { given: givenMask, theme: TOKEN_THEME, cell: 40, title: '数独の問題例', desc: '上級ナンプレの問題例' });

const trace = traceFirstElimination(sample);
let svgTech = '';
let techName = '';
if (trace) {
  // 内部技巧キー（lockedCandidates 等）を日本語名に変換して表示（英字キーの生渲染を防ぐ）
  techName = TECH_INFO[trace.step.technique]?.ja ?? 'テクニック';
  const marks: CandidateMark[] = (trace.step.eliminations ?? []).map(([cell, digit]) => ({ cell, digit, type: 'eliminate' }));
  const cells = [...new Set((trace.step.eliminations ?? []).map(([c]) => c))].map((cell) => ({ cell }));
  svgTech = renderBoardSvg(trace.grid, {
    given: givenMask,
    candidates: trace.candidates,
    cellHighlights: cells,
    candidateMarks: marks,
    theme: TOKEN_THEME,
    cell: 40,
    title: 'テクニックによる候補の消去',
    desc: '黄色のマスから赤い候補が消去される様子',
  });
}

const faq = [
  { q: 'ナンプレ（数独）の基本的なやり方は？', a: '空いているマスに1〜9を入れ、各行・各列・各3×3ブロックで同じ数字が重複しないように埋めるのが基本のやり方です。計算は一切不要で、論理だけで解けます。初めての方は<a href="/guide/rules/">ルール・遊び方</a>もあわせてどうぞ。' },
  { q: 'ナンプレを簡単に解くコツはありますか？', a: '最初の一手は、すでにヒントが多く埋まっているブロックや行から探すと簡単です。候補が少ないぶん、入る数字が一つに決まるマス（単数）が見つかりやすいからです。一マス埋まるごとに周囲の候補が変わるので、確定するたびに見直すと連鎖的に解けます。' },
  { q: '数独が解けないときはどうすればいい？', a: 'まず全空きマスに候補をメモしましょう。単数（候補が一つのマス）を確定し、それでも詰まったらペアや区画の絞り込みを使います。当てずっぽうは不要です。' },
  { q: '当てずっぽうは必要ですか？', a: 'numpredo の問題はすべて論理だけで解けるよう検証しています。必ず次の一手が論理で見つかるので、推測は要りません。' },
  { q: '数独とナンプレは違うものですか？', a: '同じパズルの別名です。「ナンバープレース（ナンプレ）」と「数独」は呼び方が違うだけで、ルールも解き方も同じです。' },
  { q: '数独の解き方のコツは何ですか？', a: 'まずヒントが多い行・列・ブロックから始め、候補メモを全マスに書きましょう。消去法で候補が一つに絞れるマスを探すのが基本のコツです。コツの詳細は<a href="/guide/tips/">解き方のコツまとめ</a>をどうぞ。' },
];
const datePublished = published['/guide/how-to-solve/'];
const dateModified = lastmod['/guide/how-to-solve/'];
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'ナンプレの解き方完全ガイド',
  description,
  inLanguage: 'ja',
  mainEntityOfPage: url,
  image: 'https://numpredo.com/og-image.png',
  author: { '@id': 'https://numpredo.com/#organization' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.lead', '.faq'] },
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
};
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '数独・ナンプレの解き方',
  description,
  step: [
    { '@type': 'HowToStep', name: '候補をメモする', text: '各空きマスに入りうる数字をメモする。' },
    { '@type': 'HowToStep', name: '単数を見つける', text: '候補が一つだけのマス、または行・列・ブロック内で一箇所だけのマスを確定する。' },
    { '@type': 'HowToStep', name: 'ペア・区画で絞り込む', text: 'ペアや区画の絞り込みで候補を消去し、新たな単数を生む。' },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '解き方ガイド', item: url },
  ],
};
---

<Base title={title} description={description} canonical={url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › 解き方</nav>
  <h1>ナンプレの解き方完全ガイド｜数独を図解で解く</h1>
  {dateModified && <p class="upd"><time datetime={dateModified}>最終更新日：{dateModified.slice(0, 10).replace(/-/g, '/')}</time></p>}
  <p class="lead">ナンプレの解き方を、単数の発見から上級テクニックまで図解でわかりやすく。初心者の一手から難問まで、すべて論理だけで解ける考え方です。</p>

  <h2>数独・ナンプレとは</h2>
  <p>9×9のマスに1〜9を入れ、各行・各列・各3×3ブロックに同じ数字が重複しないようにするパズルです。ルールの詳細は<a href="/guide/rules/">ルール・遊び方</a>へ。</p>
  <figure class="guide-fig"><Fragment set:html={svgPuzzle} /><figcaption>問題例（上級）。太字が最初から入っている数字です。</figcaption></figure>

  <h2>基本の手順</h2>
  <ol>
    <li>各空きマスに入りうる候補数字をメモする。</li>
    <li>候補が一つだけのマス（裸の単数）を確定する。</li>
    <li>行・列・ブロック内で、ある数字が一箇所にしか入らないマス（隠れた単数）を探す。</li>
    <li>詰まったら、次の「テクニック」で候補を絞り込む。</li>
  </ol>

  <h2>テクニックで候補を消去する</h2>
  <p>単数だけで止まったら、候補同士の関係を使って消去します。下図は「{techName || 'テクニック'}」の例。黄色のマスに注目すると、同じ行・列・ブロック内の他マスから候補（赤い数字）を消去できます。</p>
  {svgTech && <figure class="guide-fig"><Fragment set:html={svgTech} /><figcaption>テクニックによる消去の実例（エンジンが実際に推論した一手）。</figcaption></figure>}

  <h2>難易度別のテクニック</h2>
  <ul>
    <li><a href="/guide/beginner/">初心者のコツ</a> — 単数の見つけ方</li>
    <li><a href="/guide/advanced/">上級テクニック</a> — ペア・区画の絞り込み・X-Wing</li>
    <li><a href="/guide/sudoku-vs-numpre/">数独とナンプレの違い</a></li>
  </ul>

  <h2>テクニック別の詳しい解説（図解・早見表）</h2>
  <p>どの手筋をいつ使うかの早見表です。名前をクリックすると、図解つきの詳しい解説に進めます。</p>
  <div class="gtable-wrap">
    <table class="gtable">
      <thead><tr><th>テクニック</th><th>適用難易度</th><th>どんな場面で使うか</th></tr></thead>
      <tbody>
        {TECHNIQUES.map((t) => (
          <tr>
            <td><a href={`/guide/techniques/${t.slug}/`}>{t.name}</a></td>
            <td>{t.level}</td>
            <td>{t.lead}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2>解き方のコツまとめ</h2>
  <p>基本から中級まで、コツを段階的に学びたい方は<a href="/guide/tips/">解き方のコツまとめページ</a>へ。消去法・候補メモの書き方・ペアの見つけ方をわかりやすく解説しています。</p>

  <h2>詰まったときの対処法</h2>
  <p>どうしても解けないときのチェックリストは<a href="/guide/when-stuck/">行き詰まり解決ガイド</a>へ。候補メモの見直しから三国同盟・スワードフィッシュまで、次の一手を論理で見つける方法を解説しています。答え合わせは<a href="/tools/solver/">数独ソルバー（自動解答）</a>で確認できます。新聞・雑誌の数独で詰まったときは<a href="/guide/newspaper/">新聞の数独が解けないときの答え合わせ方法</a>もどうぞ。</p>

  <h2>難問ナンプレの解き方</h2>
  <p>難問ナンプレで単数やペアだけでは進まないときは、候補メモを最新にしてから三国同盟、隠れたペア、X-Wingの順に確認します。いきなり推測せず、<a href="/play/hard/">難問</a>で三国同盟を練習し、さらに難しい問題は<a href="/play/extreme/">超難問</a>と<a href="/guide/advanced/">上級テクニック</a>で盤面全体を見る力を鍛えましょう。</p>

  <h2>難易度を選んで練習</h2>
  <ul>
    <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a></li>
  </ul>

  <ShareBar url={url} title={title} cta="この解き方ガイドをシェア" />

  <h2>よくある質問</h2>
  <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    .upd { color: var(--ink-4); font-size: 12px; margin: -4px 0 10px; }
    main ul, main ol { line-height: 2; } main ul a, main p a { color: var(--accent); }
    .gtable-wrap { overflow-x: auto; margin: 10px 0 4px; }
    .gtable { width: 100%; border-collapse: collapse; font-size: 14px; }
    .gtable th, .gtable td { border: 1px solid var(--line-2); padding: 8px 11px; text-align: left; vertical-align: top; }
    .gtable th { background: var(--surface-2); font-weight: 700; color: var(--ink); }
    .gtable td:first-child { white-space: nowrap; }
    .faq dt { font-family: var(--font-mincho); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--ink-3); }
    .guide-fig { margin: 16px 0; text-align: center; }
    .guide-fig svg { max-width: 360px; width: 100%; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    .guide-fig figcaption { font-size: 12px; color: var(--ink-3); margin-top: 6px; }
  </style>
</Base>
