---
import Base from '../../layouts/Base.astro';
import ShareBar from '../../components/ShareBar.astro';
import advanced from '../../data/puzzles/advanced.json';
import { renderBoardSvg, gridFromString, traceFirstElimination, LIGHT_THEME, type CandidateMark } from '../../engine/index.ts';
import lastmodJson from '../../data/sitemap-lastmod.json';
const lastmod: Record<string, string> = lastmodJson;

const title = '数独・ナンプレの解き方ガイド｜図解で徹底解説 - numpredo';
const description = '数独（ナンプレ）の解き方を図解で解説。単数の発見からペア・区画の絞り込み・X-Wingまで、初心者から上級者まで使えるテクニックを唯一解・論理ベースで。';
const url = 'https://numpredo.com/guide/how-to-solve/';

// 构建期用引擎生成「題面」与「テクニック消去」の和風図解
const sample = gridFromString(advanced.puzzles[0].puzzle);
const givenMask = sample.map((v) => v !== 0);
const svgPuzzle = renderBoardSvg(sample, { given: givenMask, theme: LIGHT_THEME, cell: 40, title: '数独の問題例', desc: '上級ナンプレの問題例' });

const trace = traceFirstElimination(sample);
let svgTech = '';
let techName = '';
if (trace) {
  techName = trace.step.technique;
  const marks: CandidateMark[] = (trace.step.eliminations ?? []).map(([cell, digit]) => ({ cell, digit, type: 'eliminate' }));
  const cells = [...new Set((trace.step.eliminations ?? []).map(([c]) => c))].map((cell) => ({ cell }));
  svgTech = renderBoardSvg(trace.grid, {
    given: givenMask,
    candidates: trace.candidates,
    cellHighlights: cells,
    candidateMarks: marks,
    theme: LIGHT_THEME,
    cell: 40,
    title: 'テクニックによる候補の消去',
    desc: '黄色のマスから赤い候補が消去される様子',
  });
}

const faq = [
  { q: 'ナンプレ（数独）の基本的なやり方は？', a: '空いているマスに1〜9を入れ、各行・各列・各3×3ブロックで同じ数字が重複しないように埋めるのが基本のやり方です。計算は一切不要で、論理だけで解けます。初めての方は<a href="/guide/rules/">ルール・遊び方</a>もあわせてどうぞ。' },
  { q: 'ナンプレを簡単に解くコツはありますか？', a: '最初の一手は、すでにヒントが多く埋まっているブロックや行から探すと簡単です。候補が少ないぶん、入る数字が一つに決まるマス（単数）が見つかりやすいからです。一マス埋まるごとに周囲の候補が変わるので、確定するたびに見直すと連鎖的に解けます。' },
  { q: '数独が解けないときはどうすればいい？', a: 'まず全空きマスに候補をメモしましょう。単数（候補が一つのマス）を確定し、それでも詰まったらペアや区画の絞り込みを使います。当てずっぽうは不要です。' },
  { q: '当てずっぽうは必要ですか？', a: 'numpredo の問題はすべて論理だけで解けるよう検証しています。必ず次の一手が論理で見つかるので、推測は要りません。' },
  { q: '数独とナンプレは違うものですか？', a: '同じパズルの別名です。「ナンバープレース（ナンプレ）」と「数独」は呼び方が違うだけで、ルールも解き方も同じです。' },
  { q: '数独の解き方のコツは何ですか？', a: 'まずヒントが多い行・列・ブロックから始め、候補メモを全マスに書きましょう。消去法で候補が一つに絞れるマスを探すのが基本のコツです。コツの詳細は<a href="/guide/tips/">解き方のコツまとめ</a>をどうぞ。' },
];
const dateModified = lastmod['/guide/how-to-solve/'];
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'ナンプレ・数独の解き方完全ガイド',
  description,
  inLanguage: 'ja',
  mainEntityOfPage: url,
  image: 'https://numpredo.com/og-image.png',
  author: { '@type': 'Organization', name: 'numpredo', url: 'https://numpredo.com/' },
  publisher: { '@type': 'Organization', name: 'numpredo', logo: { '@type': 'ImageObject', url: 'https://numpredo.com/og-image.png' } },
  ...(dateModified ? { dateModified } : {}),
};
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: '数独・ナンプレの解き方',
  description,
  step: [
    { '@type': 'HowToStep', name: '候補をメモする', text: '各空きマスに入りうる数字をメモする。' },
    { '@type': 'HowToStep', name: '単数を見つける', text: '候補が一つだけのマス、または単元内で一箇所だけのマスを確定する。' },
    { '@type': 'HowToStep', name: 'ペア・区画で絞り込む', text: 'ペアや区画の絞り込みで候補を消去し、新たな単数を生む。' },
  ],
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '解き方ガイド', item: url },
  ],
};
---

<Base title={title} description={description} canonical={url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › 解き方</nav>
  <h1>ナンプレ・数独の解き方完全ガイド</h1>
  <p class="lead">単数の発見から上級テクニックまで、図解でわかりやすく。すべて唯一解・論理だけで解ける考え方です。</p>

  <h2>数独・ナンプレとは</h2>
  <p>9×9のマスに1〜9を入れ、各行・各列・各3×3ブロックに同じ数字が重複しないようにするパズルです。ルールの詳細は<a href="/guide/rules/">ルール・遊び方</a>へ。</p>
  <figure class="guide-fig"><Fragment set:html={svgPuzzle} /><figcaption>問題例（上級）。太字が最初から入っている数字です。</figcaption></figure>

  <h2>基本の手順</h2>
  <ol>
    <li>各空きマスに入りうる候補数字をメモする。</li>
    <li>候補が一つだけのマス（裸の単数）を確定する。</li>
    <li>単元内である数字が一箇所にしか入らないマス（隠れた単数）を探す。</li>
    <li>詰まったら、次の「テクニック」で候補を絞り込む。</li>
  </ol>

  <h2>テクニックで候補を消去する</h2>
  <p>単数だけで止まったら、候補同士の関係を使って消去します。下図は「{techName || 'テクニック'}」の例。黄色のマスに注目すると、同じ単元の他マスから候補（赤い数字）を消去できます。</p>
  {svgTech && <figure class="guide-fig"><Fragment set:html={svgTech} /><figcaption>テクニックによる消去の実例（エンジンが実際に推論した一手）。</figcaption></figure>}

  <h2>難易度別のテクニック</h2>
  <ul>
    <li><a href="/guide/beginner/">初心者のコツ</a> — 単数の見つけ方</li>
    <li><a href="/guide/advanced/">上級テクニック</a> — ペア・区画の絞り込み・X-Wing</li>
    <li><a href="/guide/sudoku-vs-numpre/">数独とナンプレの違い</a></li>
  </ul>

  <h2>テクニック別の詳しい解説（図解）</h2>
  <ul>
    <li><a href="/guide/techniques/naked-pair/">ネイキッドペア（二国同盟）の解き方</a></li>
    <li><a href="/guide/techniques/pointing/">区画の絞り込み（ポインティング）の解き方</a></li>
    <li><a href="/guide/techniques/x-wing/">X-Wing（エックスウイング）の解き方</a></li>
    <li><a href="/guide/techniques/hidden-pair/">隠れたペア（ヒドゥンペア）の解き方</a></li>
    <li><a href="/guide/techniques/naked-triple/">三国同盟（ネイキッドトリプル）の解き方</a></li>
    <li><a href="/guide/techniques/swordfish/">スワードフィッシュの解き方</a></li>
    <li><a href="/guide/techniques/skyscraper/">スカイスクレイパーの解き方</a></li>
  </ul>

  <h2>解き方のコツまとめ</h2>
  <p>基本から中級まで、コツを段階的に学びたい方は<a href="/guide/tips/">解き方のコツまとめページ</a>へ。消去法・候補メモの書き方・ペアの見つけ方をわかりやすく解説しています。</p>

  <h2>詰まったときの対処法</h2>
  <p>どうしても解けないときのチェックリストは<a href="/guide/when-stuck/">行き詰まり解決ガイド</a>へ。候補メモの見直しから三国同盟・スワードフィッシュまで、次の一手を論理で見つける方法を解説しています。答え合わせは<a href="/tools/solver/">数独ソルバー（自動解答）</a>で確認できます。</p>

  <h2>難易度を選んで練習</h2>
  <ul>
    <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a></li>
  </ul>

  <ShareBar url={url} title={title} cta="この解き方ガイドをシェア" />

  <h2>よくある質問</h2>
  <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

  <style is:global>
    .crumb { font-size: 12px; color: var(--sub); margin-bottom: 10px; } .crumb a { color: var(--sub); text-decoration: none; }
    .lead { color: var(--sub); font-size: 14px; margin: 0 0 16px; }
    main ul, main ol { line-height: 2; } main ul a, main p a { color: var(--ai); }
    .faq dt { font-family: var(--min); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--sub); }
    .guide-fig { margin: 16px 0; text-align: center; }
    .guide-fig svg { max-width: 360px; width: 100%; border: 1px solid var(--line); border-radius: 8px; background: var(--card); }
    .guide-fig figcaption { font-size: 12px; color: var(--sub); margin-top: 6px; }
  </style>
</Base>
