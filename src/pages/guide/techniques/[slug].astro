---
import Base from '../../../layouts/Base.astro';
import { TECHNIQUES, type Technique } from '../../../data/techniques.ts';
import { renderBoardSvg, bit, LIGHT_THEME, type CandidateMark } from '../../../engine/index.ts';

export function getStaticPaths() {
  return TECHNIQUES.map((t) => ({ params: { slug: t.slug }, props: { t } }));
}
interface Props {
  t: Technique;
}
const { t } = Astro.props;
const url = `https://numpredo.com/guide/techniques/${t.slug}/`;
const others = TECHNIQUES.filter((x) => x.slug !== t.slug);

// fig → SVG
const f = t.fig;
const givenMask = f.given.map((v) => v !== 0);
const candidates = new Array<number>(81).fill(0);
for (const k of Object.keys(f.notes)) candidates[+k] = f.notes[+k].reduce((m, d) => m | bit(d), 0);
const cellHighlights = f.highlight.map((cell) => ({ cell }));
const candidateMarks: CandidateMark[] = [];
for (const k of Object.keys(f.eliminate)) for (const d of f.eliminate[+k]) candidateMarks.push({ cell: +k, digit: d, type: 'eliminate' });
for (const cell of f.highlight) for (const d of f.notes[cell] ?? []) candidateMarks.push({ cell, digit: d, type: 'highlight' });
const svg = renderBoardSvg(f.given, { given: givenMask, candidates, cellHighlights, candidateMarks, theme: LIGHT_THEME, cell: 38, title: t.name, desc: t.figCaption });

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: t.name + 'の解き方',
  description: t.description,
  step: t.sections.map((s) => ({ '@type': 'HowToStep', name: s.h, text: s.body.join(' ').replace(/<[^>]+>/g, '') })),
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.map((q) => ({ '@type': 'Question', name: q.q, acceptedAnswer: { '@type': 'Answer', text: q.a } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '解き方', item: 'https://numpredo.com/guide/how-to-solve/' },
    { '@type': 'ListItem', position: 3, name: t.name, item: url },
  ],
};
---

<Base title={t.title} description={t.description} canonical={url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › <a href="/guide/how-to-solve/">解き方</a> › {t.name}</nav>
  <h1>{t.h1}</h1>
  <p class="lead">{t.lead}（適用：{t.level}）</p>

  {t.sections.map((s) => (<><h2>{s.h}</h2>{s.body.map((p) => <p set:html={p} />)}</>))}

  <figure class="guide-fig"><Fragment set:html={svg} /><figcaption>{t.figCaption}</figcaption></figure>

  <h2>他のテクニック</h2>
  <ul>{others.map((o) => (<li><a href={`/guide/techniques/${o.slug}/`}>{o.name}の解き方</a>（{o.level}）</li>))}</ul>

  <h2>実際に練習する</h2>
  <ul>
    <li><a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a>で練習する</li>
    <li><a href="/guide/how-to-solve/">解き方ガイドに戻る</a> ・ <a href="/guide/advanced/">上級テクニック一覧</a> ・ <a href="/tools/solver/">数独ソルバーで答え合わせ</a></li>
  </ul>

  <h2>よくある質問</h2>
  <dl class="faq">{t.faq.map((q) => (<><dt>{q.q}</dt><dd>{q.a}</dd></>))}</dl>

  <style is:global>
    .crumb { font-size: 12px; color: var(--sub); margin-bottom: 10px; } .crumb a { color: var(--sub); text-decoration: none; }
    .lead { color: var(--sub); font-size: 14px; margin: 0 0 16px; }
    main ul { line-height: 2; } main ul a, main p a { color: var(--ai); }
    .faq dt { font-family: var(--min); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--sub); }
    .guide-fig { margin: 16px auto; text-align: center; max-width: 380px; }
    .guide-fig svg { width: 100%; border: 1px solid var(--line); border-radius: 8px; background: var(--card); }
    .guide-fig figcaption { font-size: 12px; color: var(--sub); margin-top: 6px; }
  </style>
</Base>
