---
// 個人統計・実績ページ。データは全部端末の localStorage——個人データなので noindex。
import Base from '../layouts/Base.astro';
const title = 'あなたの統計・実績 - numpredo';
const description = 'クリア数・最速タイム・連続日数などのプレイ統計と、解いて集める実績の一覧。記録はお使いの端末にだけ保存されます（登録不要・サーバー送信なし）。';
---

<Base title={title} description={description} noindex>
  <nav class="crumb"><a href="/">ホーム</a> › 統計・実績</nav>
  <h1>あなたの統計・実績</h1>
  <p class="lead">クリア記録と実績はお使いの端末（ブラウザ）にだけ保存されます。登録不要・サーバー送信なし。ブラウザのデータを消すと記録もリセットされます。</p>

  <div id="stats-mount"></div>

  <h2>もっと遊ぶ</h2>
  <ul>
    <li><a href="/daily/">今日の一問</a> ・ <a href="/daily/archive/">過去のデイリー（アーカイブ）</a></li>
    <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a></li>
  </ul>

  <script>
    import '../client/stats-page.ts';
  </script>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 18px; }
    main ul { line-height: 2; }
    .st-tiles { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 12px; margin: 6px 0 10px; }
    .st-tile { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 14px; text-align: center; }
    .st-tile-v { font-family: var(--font-mincho); font-size: 22px; font-weight: 700; color: var(--accent); }
    .st-tile-h { font-size: 12px; color: var(--ink-3); margin-top: 4px; }
    .st-twrap { overflow-x: auto; }
    .st-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .st-table th, .st-table td { border: 1px solid var(--line-2); padding: 8px 11px; text-align: left; }
    .st-table th { background: var(--surface-2); font-weight: 700; }
    .st-achv { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 10px; }
    .st-a { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-sm); padding: 10px 12px; font-size: 13px; opacity: .55; }
    .st-a.on { opacity: 1; border-color: var(--accent); }
    .st-a b { display: inline-block; margin: 0 6px 2px 0; }
    .st-a-ic { margin-right: 6px; }
    .st-a-d { display: block; font-size: 12px; color: var(--ink-3); }
    .st-empty { color: var(--ink-3); font-size: 14px; margin-top: 14px; }
  </style>
</Base>
