---
import Base from '../../layouts/Base.astro';
import lastmodJson from '../../data/sitemap-lastmod.json';
import publishedJson from '../../data/published.json';
const lastmod: Record<string, string> = lastmodJson;
const published: Record<string, string> = publishedJson;

const title = '数独・ナンプレ自動解答｜カメラで撮るだけ答え合わせ（無料・画像もOK）- numpredo';
const description = '新聞・雑誌の数独・ナンプレが解けないときに。カメラで撮る・画像を選ぶだけで盤面を自動読み取りし、答えを瞬時に自動計算。手入力にも対応。9×9標準数独の答え合わせ・自動解答ソルバーが無料・登録不要、スマホでもPCでも使えます。';
const url = 'https://numpredo.com/tools/solver/';
const datePublished = published['/tools/solver/'];
const dateModified = lastmod['/tools/solver/'];
const dateModifiedLabel = dateModified?.slice(0, 10).replace(/-/g, '/');
const faq = [
  { q: '写真から問題を読み取れますか？', a: 'はい。新聞や雑誌の数独・ナンプレを撮影、またはスクリーンショットを選ぶと、盤面のマス目を自動で読み取り、上の盤面に反映します。明るく、なるべく正面から撮るときれいに読み取れます。' },
  { q: '読み取りが間違っていたら？', a: '読み取りは完璧ではありません。反映された盤面を見て、間違っているマスをタップ（クリック）して数字キーで直してから「解く」を押してください。最初から手入力で使うこともできます。' },
  { q: 'ナンプレ・数独を自動で解いてくれますか？', a: 'はい。盤面を入力（または写真から読み取り）して「解く」を押すと、解答プログラムが自動で計算し、答えの盤面を表示します。新聞・雑誌の答え合わせ・解読にもお使いいただけます。' },
  { q: '答え合わせだけしたいときも使えますか？', a: 'はい。自分で解いた答えが合っているか確かめたいときも、問題のマスを入力すれば正しい解答が表示されるので、答え合わせに使えます。無料・登録不要です。' },
  { q: '数独・ナンプレを解いてくれるサイトを探しているのですが？', a: 'このページがまさにそれです。無料の自動解答サイトとして、盤面を入力（または写真読み取り）するだけで答えを表示します。登録・アプリ不要でブラウザだけで使えます。' },
  { q: '解答ツールとして途中式（解く手順）も見られますか？', a: '見られます。「解く」を押すと、答えの盤面の下に途中式（解く手順）が盤面の図つきで並びます。各ステップに使った手筋の名前と消える候補が表示されるので、どこから読んでもその一手の根拠がわかります。' },
  { q: '解が複数ある問題でも使えますか？', a: '入力した問題が「唯一解か」を自動で判定します。解が複数ある場合はその旨を表示し、一例を解答します。自力で解きたい方は<a href="/guide/how-to-solve/">解き方ガイド</a>をどうぞ。' },
  { q: '6×6 や変則ルール（キラー・対角線など）も解けますか？', a: 'このソルバーが対応しているのは 9×9 の標準的な数独（ナンプレ）です。6×6 などのサイズ違いや、キラー数独・対角線数独といった変則ルールには現在対応していません。各バリエーションのルールは<a href="/variants/6x6/">6×6数独</a>や<a href="/variants/killer/">キラー数独</a>の解説ページでご紹介しています。' },
  { q: 'このソルバーは数独の解き方も教えてくれますか？', a: 'はい。「解く」を押すと、答えだけでなく論理だけで解く手順を一手ずつ図解で表示します。どの手筋を使うか、どのマスから埋まるかが分かるので、解き方の練習になります。手筋ごとのくわしい解説は<a href="/guide/how-to-solve/">解き方完全ガイド</a>をどうぞ。' },
];
const webAppSchema = {
  '@context': 'https://schema.org', '@type': 'WebApplication',
  name: '数独・ナンプレ自動解答ツール（写真ソルバー）', description, url,
  applicationCategory: 'UtilitiesApplication', operatingSystem: 'Web', inLanguage: 'ja',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
};
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' }, { '@type': 'ListItem', position: 2, name: 'プレイ', item: 'https://numpredo.com/play/' }, { '@type': 'ListItem', position: 3, name: 'ソルバー', item: url }] };
// HowTo：ページ内の「写真で解く手順」を構造化データ化（写真/カメラで解く方法の意図に対応、リッチリザルト対象）
const howToSchema = {
  '@context': 'https://schema.org', '@type': 'HowTo',
  name: '写真で数独・ナンプレを自動で解く方法',
  description: '新聞・雑誌の数独やナンプレを、写真を撮る／画像を選ぶだけで自動読み取りし、答えを自動計算する手順。',
  inLanguage: 'ja', totalTime: 'PT1M',
  tool: { '@type': 'HowToTool', name: 'numpredo 数独・ナンプレ自動解答ツール' },
  step: [
    { '@type': 'HowToStep', position: 1, name: '写真を撮る・画像を選ぶ', text: 'スマホのカメラで数独の紙面を撮影するか、画像・スクリーンショットを選びます。盤面が画面いっぱいになるよう、明るい場所で正面から撮るときれいに読み取れます。', url: url + '#sv-app' },
    { '@type': 'HowToStep', position: 2, name: '読み取った盤面を確認・修正する', text: '自動で読み取った数字が上の盤面に反映されます。間違っているマスをタップして数字キーで直します。手入力だけでも使えます。', url: url + '#sv-app' },
    { '@type': 'HowToStep', position: 3, name: '「解く」を押す', text: '「解く」を押すと答えを自動計算して表示します。論理だけで解く手順も一手ずつ図解されるので、答え合わせと解き方の学習が同時にできます。', url: url + '#sv-steps' },
  ],
};
---

<Base title={title} description={description} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › <a href="/play/">プレイ</a> › ソルバー</nav>
  <h1>数独・ナンプレ自動解答ツール（写真でかんたん答え合わせ）</h1>
  <p class="lead">新聞・雑誌の数独（ナンプレ）を、<strong>カメラで撮る／画像を選ぶだけ</strong>で自動読み取りして答えを計算します。手入力でもOK、無料・登録不要（<strong>9×9 の標準ルール専用</strong>）。</p>
  {dateModifiedLabel && <p class="sv-updated"><time datetime={dateModified}>最終更新日：{dateModifiedLabel}</time></p>}

  <div class="sv-photo">
    <label class="sv-photo-btn sv-photo-cam"><input type="file" accept="image/*" capture="environment" data-photo hidden />カメラで撮影</label>
    <label class="sv-photo-btn"><input type="file" accept="image/*" data-photo hidden />画像・スクショを選ぶ</label>
    <span class="sv-photo-or">または下の盤面に直接入力</span>
  </div>

  <p id="sv-msg" class="sv-msg"></p>
  <div id="sv-app">
    {/* 静的スケルトン盤面：JS 読み込み前の空白を防ぐ（ocr-solve.ts が innerHTML='' で置換） */}
    <div class="sv-layout" aria-hidden="true">
      <div class="sv-board">
        {Array.from({ length: 81 }, (_, i) => {
          const r = (i / 9) | 0;
          const c = i % 9;
          return <div class={`sv-cell${c === 2 || c === 5 ? ' sv-br' : ''}${r === 2 || r === 5 ? ' sv-bb' : ''}`} />;
        })}
      </div>
    </div>
  </div>

  <div id="sv-steps" class="sv-steps" hidden></div>

  <h2>答えだけでなく「数独・ナンプレの解き方」も一手ずつ表示します</h2>
  <p>このソルバーは答えを出すだけではありません。「解く」を押すと、その問題を<strong>論理だけで解く手順</strong>を一手ずつ図解（解き方の手順）で表示します。どのマスから埋まるのか、どの手筋（テクニック）を使うのかを盤面付きで確認できるので、新聞・雑誌の答え合わせをしながら<strong>数独・ナンプレの解き方そのものを学べます</strong>。難易度の目安（初級〜超難問）も自動で判定します。</p>
  <p>判定できる手筋は<a href="/guide/techniques/naked-pair/">ペア（二国同盟）</a>・<a href="/guide/techniques/x-wing/">X-Wing</a>・<a href="/guide/techniques/swordfish/">スワードフィッシュ</a>・<a href="/guide/techniques/skyscraper/">スカイスクレイパー</a>など、上級者向けの手筋まで対応。難問・超難問の答え合わせでも、どの手筋で解けるのかを図解します。一つひとつの解き方は<a href="/guide/how-to-solve/">解き方完全ガイド</a>でくわしく解説しています。当てずっぽうなしで、論理だけで解けるのが数独の魅力です。</p>

  <h2>新聞の数独が写真で解けない時は？</h2>
  <p>盤面が画面いっぱいになるよう正面から明るい場所で撮影し、読み取り後に盤面を確認・修正してから「解く」を押せば解けます。うまく読み取れないマスは、タップして数字キーで手直しできます。</p>

  <h2>カメラの使い方解説｜写真・画像で数独・ナンプレを解く方法（スマホ対応）</h2>
  <p>スマホのカメラで撮影、または画像・スクリーンショットを選ぶだけで、数独・ナンプレの盤面を自動で読み取ります。読み取った数字は上の盤面に反映されるので、間違っているマスをタップして直し、「解く」を押すだけ。新聞や雑誌の数独を写真に撮って答え合わせするのに便利です。</p>
  <p>きれいに読み取るコツ：</p>
  <ul>
    <li>盤面が画面いっぱいになるよう、なるべく正面から撮る</li>
    <li>明るい場所で、影や反射が入らないようにする</li>
    <li>対応しているのは 9×9 の標準的な数独のみ</li>
  </ul>
  <p>読み取りは完璧ではないため、反映された盤面を確認・修正してから「解く」を押してください。<strong>画像はお使いの端末内だけで処理され、サーバーには送信されません。</strong></p>

  <h2>新聞・雑誌の数独／ナンプレの答え合わせに</h2>
  <p>新聞（読売・毎日・朝日など）や雑誌のナンプレ・数独が解けないとき、紙面の答え発表を待たずに答え合わせができます。問題を撮影するか、マス目を入力して「解く」を押すだけ。唯一解かどうかも判定します。くわしくは<a href="/guide/newspaper/">新聞の数独・ナンプレが解けないときの答え合わせ方法</a>をどうぞ。</p>
  <p>答え合わせのやり方は3ステップです：</p>
  <ol>
    <li>紙面の<strong>問題</strong>（自分の答えではなく、最初から印刷されている数字）を撮影するか、上の盤面に入力する。</li>
    <li>読み取り結果を確認し、間違っているマスをタップして修正する。</li>
    <li>「解く」を押して正しい解答を表示し、自分の答えと見比べる。違うマスがあれば、そこが間違いです。</li>
  </ol>

  <h2>ナンプレ・数独の自動解答について</h2>
  <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a}></dd></>))}</dl>

  <h2>関連</h2>
  <ul>
    <li><a href="/guide/newspaper/">新聞の数独・ナンプレが解けないとき</a></li>
    <li><a href="/guide/how-to-solve/">自力で解くための解き方ガイド</a></li>
    <li><a href="/play/advanced/">上級をプレイ</a></li>
  </ul>

  <script>
    import '../../client/ocr-solve.ts';
  </script>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    .sv-updated { color: var(--ink-4); font-size: 12px; margin: -10px 0 16px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .faq dt { font-weight: 700; margin-top: 14px; } .faq dd { margin: 4px 0 0; color: var(--ink-3); font-size: 14px; } .faq a { color: var(--accent); }

    .sv-photo { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; margin: 0 0 14px; }
    .sv-photo-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: var(--accent-on); font-size: var(--text-base); font-weight: 700; padding: 12px 20px; border-radius: var(--radius); cursor: pointer; }
    .sv-photo-btn:hover { background: var(--accent-ink); }
    .sv-photo-or { font-size: var(--text-sm); color: var(--ink-4); }

    .sv-layout { display: grid; grid-template-columns: 1fr 280px; gap: 24px; align-items: start; max-width: 760px; }
    .sv-board { display: grid; grid-template-columns: repeat(9, 1fr); aspect-ratio: 1; max-width: 460px; margin: 0 auto; border: 2px solid var(--board-edge); background: var(--board-bg); border-radius: 4px; overflow: hidden; }
    /* aria 行容器（role=row）不参与布局；盘面/键盘禁文字选中（触控连点不弹选字） */
    .sv-rowg { display: contents; }
    .sv-board, .sv-pad, .sv-ctrl { -webkit-user-select: none; user-select: none; }
    .sv-cell { border: 0.5px solid var(--cell-line); background: transparent; display: flex; align-items: center; justify-content: center; font-size: clamp(18px, 4.2vw, 26px); cursor: pointer; padding: 0; color: var(--ink-4); font-family: var(--font-sans); }
    .sv-cell.sv-br { border-right: 2px solid var(--box-line); }
    .sv-cell.sv-bb { border-bottom: 2px solid var(--box-line); }
    .sv-cell.sv-given { color: var(--num-given); font-family: var(--font-mincho); font-weight: 700; }
    .sv-cell.sv-sel { background: var(--cell-sel-bg); box-shadow: inset 0 0 0 2px var(--accent); }
    .sv-cell.sv-err { color: var(--num-error) !important; background: var(--cell-error-bg); text-decoration: underline wavy; text-underline-offset: 2px; }
    .sv-cell.sv-solved { color: var(--num-user); font-weight: 700; }

    .sv-pad { display: grid; grid-template-columns: repeat(5, 1fr); gap: 7px; }
    .sv-key { padding: 14px 0; font-size: 20px; border: 1px solid var(--key-line); border-radius: 6px; background: var(--key-bg); color: var(--key-ink); cursor: pointer; font-family: var(--font-mincho); }
    .sv-key:hover { background: var(--key-hover); }
    .sv-del { font-size: 13px; font-family: var(--font-sans); color: var(--ink-3); }
    .sv-ctrl { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .sv-go { flex: 1 1 100%; padding: 13px 0; border: 0; border-radius: var(--radius); background: var(--accent); color: var(--accent-on); font-size: var(--text-md); font-weight: 700; cursor: pointer; }
    .sv-go:hover { background: var(--accent-ink); }
    .sv-sub { flex: 1 1 40%; padding: 10px 0; border: 1px solid var(--line-2); border-radius: var(--radius); background: var(--surface); color: var(--ink); font-size: var(--text-sm); cursor: pointer; }
    .sv-sub:hover { border-color: var(--accent); color: var(--accent); }

    /* 静态骨架(aria-hidden)不可交互:不给手型指针,避免 JS 未加载时的可点击假象 */
    #sv-app [aria-hidden='true'] .sv-cell { cursor: default; }
    .sv-msg { font-size: 13px; color: var(--ink-3); margin: 0 0 10px; min-height: 1.2em; }
    .sv-msg.ok { color: var(--accent); }
    .sv-msg.warn { color: var(--ink-2); }
    .sv-msg.err { color: var(--num-error); }

    .sv-steps { max-width: 760px; margin: 18px auto 0; }
    .sv-steps h2 { margin-top: 8px; }
    .sv-steps-badge { font-size: var(--text-sm); color: var(--ink-2); margin: 0 0 4px; }
    .sv-steps-intro { font-size: 13px; color: var(--ink-3); margin: 0 0 12px; }
    .sv-steps-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 16px; }
    .sv-step { margin: 0; }
    .sv-step svg { width: 100%; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    .sv-step figcaption { font-size: 12px; color: var(--ink-3); margin-top: 6px; } .sv-step figcaption a { color: var(--accent); }
    .sv-step p { font-size: 13px; color: var(--ink-3); margin: 6px 0 0; line-height: 1.6; }
    .sv-next { font-size: 13px; color: var(--ink-3); margin: 16px 0 0; padding: 10px 12px; background: var(--surface-2); border-radius: 6px; line-height: 1.9; }
    .sv-next a { color: var(--accent); }
    @media (max-width: 560px) { .sv-steps-grid { grid-template-columns: 1fr; } }

    @media (min-width: 761px) { .sv-photo-cam { display: none; } }
    @media (max-width: 760px) {
      .sv-layout { grid-template-columns: 1fr; gap: 14px; max-width: 520px; }
      .sv-board { max-width: min(100%, 52vh); }
      .sv-cell { font-size: clamp(20px, 6.2vw, 30px); }
      .sv-pad { gap: 8px; }
      .sv-key { padding: 16px 0; font-size: 22px; }
      .sv-photo-btn { flex: 1 1 100%; justify-content: center; }
      .sv-photo-or { display: none; }
    }
    .fsh { display: none; }
  </style>
</Base>
