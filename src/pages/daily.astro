---
import Base from '../layouts/Base.astro';
import SudokuGame from '../components/SudokuGame.astro';
import daily from '../data/puzzles/daily.json';
// —— 日替わり選題：EPOCH（上线日）起算的「日序号 → 池内序号」顺序映射 ——
// ① 顺序索引（非取模散射）+ daily.json 追加模式前缀稳定（gen-pool.ts）⇒ 扩库部署不再中途换当天的题；
// ② HTML 只嵌入 [构建日-1, +WINDOW-1] 的窗口（全池 485 题 ≈55KB → 90 题 ≈10KB）；
//    构建停滞超过窗口时客户端按窗口取模兜底（仍全员一致，只是复用窗口内题目）。
// solution は配信しない（HTML 肥大化を避ける）——クライアントが solveOne で現算する。
const EPOCH = Math.floor(Date.UTC(2026, 5, 14) / 86400000); // 2026-06-14（JST 上线日）的日序号
const todayIdx = Math.floor((Date.now() + 9 * 3600 * 1000) / 86400000); // 构建时的 JST 日序号
const WINDOW = 90;
const dayStart = todayIdx - 1; // 留 1 天余量：时钟略慢的端末跨日毫秒差也取得到
const pool = daily.puzzles;
const idxFor = (d: number): number => {
  const k = d - EPOCH;
  return k < pool.length ? Math.max(0, k) : k % pool.length; // 池耗尽（485 天后）才回绕
};
const set = Array.from({ length: WINDOW }, (_, o) => {
  const p = pool[idxFor(dayStart + o)];
  return { puzzle: p.puzzle, level: p.level };
});
// 難易度の内訳（題庫全量から実測。構築日に依存しない確定値＝静的本文として安全）
const LEVEL_JA: Record<string, string> = { beginner: '初級', intermediate: '中級', advanced: '上級', hard: '難問', extreme: '超難問' };
const levelCounts = pool.reduce<Record<string, number>>((m, p) => ((m[p.level] = (m[p.level] ?? 0) + 1), m), {});
const levelOrder = ['beginner', 'intermediate', 'advanced', 'hard', 'extreme'];

const title = '毎日の数独・ナンプレ｜日替わり問題で記録に挑戦 - numpredo';
const description = '毎日0時に更新、その日の数独（ナンプレ）の一問に挑戦。全員が同じ問題でタイムを競い、連続日数（ストリーク）を伸ばせます。すべて唯一解・論理だけで解ける高品質問題。メモ・自動チェックつき、無料・登録不要でスマホ・PCに対応。';
const url = 'https://numpredo.com/daily/';

const faq = [
  { q: '毎日の問題はいつ更新されますか？', a: '日付が変わるタイミング（毎日0時）で、新しい一問に切り替わります。その日のうちは、何度開いても同じ問題です。' },
  { q: '連続記録（ストリーク）はどこに保存されますか？', a: 'タイムと連続記録は、お使いの端末のブラウザ内（ローカルストレージ）に保存されます。登録不要で、サーバーには送信されません。ブラウザのデータを消すと記録もリセットされます。' },
  { q: 'なぜ全員に同じ問題なのですか？', a: '毎日、全員が同じ一問に挑戦するので、タイムを比べて腕試しができます。日替わりの一問を習慣にして、論理的思考のトレーニングに最適です。' },
  { q: '昨日の問題はもう遊べませんか？', a: 'デイリーは日替わりのため、遊べるのは当日の一問のみです。たくさん解きたい方は、<a href="/play/advanced/">難易度別のプレイ</a>や<a href="/print/">無料PDF問題集</a>をどうぞ。' },
  { q: '今日の一問で行き詰まったら？', a: '答えがどうしても分からないときは、<a href="/tools/solver/">数独ソルバー（自動解答）</a>に盤面を入力すると答えを自動表示できます。次の一手だけ知りたい方は<a href="/guide/when-stuck/">行き詰まり解決ガイド</a>もどうぞ。' },
];

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '毎日の数独（ナンプレ）',
  description,
  url,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web',
  inLanguage: 'ja',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
};
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '毎日の数独', item: url },
  ],
};
---

<Base title={title} description={description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="px-text">
    <nav class="crumb"><a href="/">ホーム</a> › 毎日</nav>
    <h1>毎日の数独・ナンプレ</h1>
  </div>

  <SudokuGame level="advanced" levelJa="毎日" daily url={url} set={set} daystart={dayStart} />

  <div class="px-text">
    <p class="lead">毎日、全員に同じ一問が出題されます。タイムを記録して、連続記録（◯日連続）を伸ばしましょう。すべて唯一解・論理だけで解ける高品質問題です。</p>

    <h2>毎日の数独・ナンプレについて</h2>
    <p>毎日0時に、新しい数独（ナンプレ）の一問が出題されます。全員に同じ問題が配られるので、タイムを記録して自己ベストや連続記録（ストリーク）に挑戦できます。難易度は日替わりで、やさしい日もあれば手強い日もあります。</p>
    <p>出題されるのはすべて「解が一つだけ」「論理だけで解ける」ことを検証済みの高品質問題です。当てずっぽうは一切不要——毎日の一問で、無理なく論理的思考のトレーニングを続けられます。登録もアプリも不要、開いたその場で遊べます。</p>

    <h2>出題の仕組みと難易度の内訳</h2>
    <p>デイリー問題は、公開日順に並べた出題リストを毎日一問ずつ順番に消化していく方式です。乱数ではなく日付から一意に決まるため、<strong>世界中の誰が開いても、同じ日にはかならず同じ問題</strong>になります。日付の切り替えは日本標準時（JST）の0時です。</p>
    <p>出題リストには現在<strong>{pool.length}問</strong>が登録されており、内訳は{levelOrder.map((lv, i) => `${LEVEL_JA[lv]}${levelCounts[lv] ?? 0}問`).join('・')}。約{Math.round((pool.length / 365) * 10) / 10}年ぶんの日替わり問題が、重複なしで用意されています。すべて自社エンジンが生成し、唯一解・論理だけで解けることを機械検証済みです。</p>
    <p>ストリーク（連続日数）を伸ばすコツ：難しい日は<a href="/guide/when-stuck/">行き詰まったときのチェックリスト</a>で候補メモを見直すこと。それでも解けない日は<a href="/tools/solver/">ソルバー</a>で一手だけ確認して、翌日また挑戦しましょう。</p>

    <h2>もっと遊ぶ</h2>
    <ul>
      <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a></li>
      <li><a href="/guide/how-to-solve/">解き方ガイド</a> ・ <a href="/print/">問題集を印刷</a> ・ <a href="/tools/solver/">自動解答ソルバー</a></li>
    </ul>

    <h2>よくある質問</h2>
    <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

    <p class="note">※ タイムと連続記録はお使いの端末に保存されます（登録不要）。日付が変わると新しい問題に切り替わります。</p>
  </div>

  <style is:global>
    .px-text { max-width: 1060px; margin: 0 auto; }
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .faq dt { font-weight: 700; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--ink-3); } .faq a { color: var(--accent); }
    .note { font-size: 13px; color: var(--ink-3); margin-top: 18px; }

    @media (max-width: 760px) {
      .px-text { padding: 0; }
      .crumb { display: none; }
      .px-text h1 { font-size: var(--text-lg); margin: 0 0 8px; }
    }
  </style>
</Base>
