---
import Base from '../layouts/Base.astro';
import SudokuGame from '../components/SudokuGame.astro';
import beginner from '../data/puzzles/beginner.json';
import intermediate from '../data/puzzles/intermediate.json';
import advanced from '../data/puzzles/advanced.json';
import hard from '../data/puzzles/hard.json';
import extreme from '../data/puzzles/extreme.json';
// —— 毎日5問（全難易度）：EPOCH（上线日）起算的「日序号 k → 各档題庫 puzzles[55+k]」——
// ① 各档跳过前 55 道（= SETS_PER_LEVEL，図解頁 No.1〜55 専用，同期点）避免与图解页重题；
// ② 顺序索引 + 題庫追加模式前缀稳定（gen-pool.ts）⇒ 扩库部署不再中途换当天的题；
// ③ HTML 只嵌入 [构建日-1, +WINDOW) 窗口 × 5 档的平坦数组（1 日 = LV_ORDER5 順の 5 エントリ）；
// ④ solution 不配信（HTML 肥大化回避）——クライアントが solveOne で現算（アクティブタブのみ）。
const EPOCH = Math.floor(Date.UTC(2026, 5, 14) / 86400000); // 2026-06-14（JST 上线日）的日序号
const todayIdx = Math.floor((Date.now() + 9 * 3600 * 1000) / 86400000); // 构建时的 JST 日序号
const WINDOW = 60;
const SETS_SKIP = 55; // = SETS_PER_LEVEL（同步点：play/[level]/[n].astro）
const dayStart = todayIdx - 1; // 留 1 天余量：时钟略慢的端末跨日毫秒差也取得到
const POOLS5 = [beginner, intermediate, advanced, hard, extreme]; // = 客户端 LV_ORDER5 順
const LV5 = ['beginner', 'intermediate', 'advanced', 'hard', 'extreme'];
const startK = dayStart - EPOCH;
// 実効窗口：任一档題庫尽きたらそこまで（hard 是最小池，尽きる前に gen:pool 追加すること）
const effWindow = Math.max(
  1,
  Math.min(WINDOW, ...POOLS5.map((p) => p.puzzles.length - SETS_SKIP - startK)),
);
const set = Array.from({ length: effWindow * 5 }, (_, i) => {
  const o = (i / 5) | 0;
  const li = i % 5;
  const p = POOLS5[li].puzzles[SETS_SKIP + startK + o];
  return { puzzle: p.puzzle, level: LV5[li] };
});
// 難易度の内訳（題庫全量から実測。構築日に依存しない確定値＝静的本文として安全）
const LEVEL_JA: Record<string, string> = { beginner: '初級', intermediate: '中級', advanced: '上級', hard: '難問', extreme: '超難問' };
const poolTotal = POOLS5.reduce((s, p) => s + p.puzzles.length, 0);
const runwayDays = Math.min(...POOLS5.map((p) => p.puzzles.length - SETS_SKIP)); // 最小池基準の連続日数

const title = '毎日の数独・ナンプレ｜日替わり5問（初級〜超難問）無料 - numpredo';
const description = '毎日0時に更新、初級から超難問まで全難易度の日替わり数独（ナンプレ）5問に挑戦。全員が同じ問題でタイムを競い、連続日数（ストリーク）や一日五冠を目指せます。すべて唯一解・論理だけで解ける高品質問題。無料・登録不要でスマホ・PCに対応。';
const url = 'https://numpredo.com/daily/';

const faq = [
  { q: '毎日の問題はいつ更新されますか？', a: '日付が変わるタイミング（毎日0時・日本時間）で、新しい5問に切り替わります。その日のうちは、何度開いても同じ問題です。' },
  { q: '難易度は選べますか？', a: 'はい。毎日、初級・中級・上級・難問・超難問の5問が出題され、盤面上のタブで自由に切り替えられます。1問だけでも連続記録は伸びるので、その日の気分に合う難易度からどうぞ。5問すべて解くと「一日五冠」です。' },
  { q: '連続記録（ストリーク）はどこに保存されますか？', a: 'タイムと連続記録は、お使いの端末のブラウザ内（ローカルストレージ）に保存されます。登録不要で、サーバーには送信されません。ブラウザのデータを消すと記録もリセットされます。' },
  { q: 'なぜ全員に同じ問題なのですか？', a: '毎日、全員が同じ問題に挑戦するので、タイムを比べて腕試しができます。日替わりの問題を習慣にして、論理的思考のトレーニングに最適です。' },
  { q: '昨日の問題はもう遊べませんか？', a: '遊べます。解き逃した日の問題は<a href="/daily/archive/">アーカイブ</a>からいつでも挑戦できます（連続記録の対象は当日の問題のみ）。たくさん解きたい方は<a href="/play/advanced/">難易度別のプレイ</a>や<a href="/print/">無料PDF問題集</a>もどうぞ。' },
  { q: '今日の問題で行き詰まったら？', a: '答えがどうしても分からないときは、<a href="/tools/solver/">数独ソルバー（自動解答）</a>に盤面を入力すると答えを自動表示できます。次の一手だけ知りたい方は<a href="/guide/when-stuck/">行き詰まり解決ガイド</a>もどうぞ。' },
];

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '毎日の数独（ナンプレ）日替わり5問',
  description,
  url,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web',
  inLanguage: 'ja',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
};
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: '毎日の数独', item: url },
  ],
};
---

<Base title={title} description={description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="px-text">
    <nav class="crumb"><a href="/">ホーム</a> › 毎日</nav>
    <h1>毎日の数独・ナンプレ</h1>
  </div>

  <SudokuGame level="advanced" levelJa="毎日" daily multi url={url} set={set} daystart={dayStart} />

  <div class="px-text">
    <p class="lead">毎日、初級から超難問まで<strong>全難易度の5問</strong>が出題されます。どれか1問で連続記録が伸び、5問すべて解けば「一日五冠」。すべて唯一解・論理だけで解ける高品質問題です。</p>

    <h2>毎日の数独・ナンプレについて</h2>
    <p>毎日0時に、初級・中級・上級・難問・超難問の新しい5問が出題されます。盤面上のタブで難易度を切り替えられ、全員に同じ問題が配られるので、タイムを記録して自己ベストや連続記録（ストリーク）に挑戦できます。今日は気軽に初級だけ、週末は五冠を狙って全難易度——自分のペースでどうぞ。</p>
    <p>出題されるのはすべて「解が一つだけ」「論理だけで解ける」ことを検証済みの高品質問題です。当てずっぽうは一切不要——毎日の問題で、無理なく論理的思考のトレーニングを続けられます。登録もアプリも不要、開いたその場で遊べます。</p>

    <h2>今月のカレンダー</h2>
    <p>クリアした日には ✓ が付きます。解き逃した日をタップすると、<a href="/daily/archive/">アーカイブ</a>でその日の問題に挑戦できます（連続記録の対象外）。記録は<a href="/stats/">統計・実績ページ</a>にまとまっています。</p>
    {/* maxday = 構築日の前日（同デプロイの archive.astro が埋め込む最終日と一致。ビルド停滞時、
        それ以降の過去日はリンクにしない——アーカイブ側でクランプされ別日の題が出る混乱を防ぐ） */}
    <div data-daily-cal data-epoch={EPOCH} data-maxday={todayIdx - 1} class="dc"></div>

    <h2>出題の仕組みと題庫の規模</h2>
    <p>デイリー問題は、各難易度の題庫を公開日順に毎日1問ずつ消化していく方式です。乱数ではなく日付から一意に決まるため、<strong>世界中の誰が開いても、同じ日にはかならず同じ5問</strong>になります。日付の切り替えは日本標準時（JST）の0時です。</p>
    <p>題庫には現在、{POOLS5.map((p, i) => `${LEVEL_JA[LV5[i]]}${p.puzzles.length}問`).join('・')}の合計<strong>{poolTotal}問</strong>が収録されており、日替わり出題は公開開始から約{Math.round((runwayDays / 365) * 10) / 10}年ぶん重複なしで用意されています。すべて自社エンジンが生成し、唯一解・論理だけで解けることを機械検証済みです。</p>
    <p>ストリーク（連続日数）を伸ばすコツ：まずはその日の得意な難易度を1問——それだけで記録は伸びます。難しい問題は<a href="/guide/when-stuck/">行き詰まったときのチェックリスト</a>で候補メモを見直し、それでも解けない日は<a href="/tools/solver/">ソルバー</a>で一手だけ確認して、翌日また挑戦しましょう。</p>

    <h2>もっと遊ぶ</h2>
    <ul>
      <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a> / <a href="/play/hard/">難問</a> / <a href="/play/extreme/">超難問</a></li>
      <li><a href="/guide/how-to-solve/">解き方ガイド</a> ・ <a href="/print/">問題集を印刷</a> ・ <a href="/tools/solver/">自動解答ソルバー</a></li>
    </ul>

    <h2>よくある質問</h2>
    <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

    <p class="note">※ タイムと連続記録はお使いの端末に保存されます（登録不要）。日付が変わると新しい問題に切り替わります。</p>
  </div>

  <script>
    import '../client/daily-calendar.ts';
  </script>

  <style is:global>
    .dc { max-width: 380px; margin: 0 0 18px; }
    .dc-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px; }
    .dc-title { font-family: var(--font-mincho); font-weight: 700; }
    .dc-nav { border: 1px solid var(--line-2); background: var(--surface); color: var(--ink-2); border-radius: 4px; width: 28px; height: 28px; cursor: pointer; }
    .dc-nav:disabled { opacity: .35; cursor: default; }
    .dc-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 3px; }
    .dc-w { font-size: 11px; color: var(--ink-4); text-align: center; padding: 2px 0; }
    .dc-cell { position: relative; display: flex; align-items: center; justify-content: center; aspect-ratio: 1; font-size: 13px; border: 1px solid var(--line); border-radius: 4px; color: var(--ink-2); text-decoration: none; background: var(--surface); }
    a.dc-cell:hover { border-color: var(--accent); color: var(--accent); }
    .dc-void, .dc-out { border: 0; background: transparent; color: var(--ink-4); opacity: .45; }
    .dc-done { background: var(--accent-tint); border-color: var(--accent); color: var(--accent-ink); font-weight: 700; }
    .dc-done i { position: absolute; right: 2px; bottom: 0; font-size: 9px; font-style: normal; color: var(--accent); }
    .dc-today { box-shadow: inset 0 0 0 2px var(--accent); }
    .dc-sel { outline: 2px dashed var(--accent); outline-offset: 1px; }

    .px-text { max-width: 1060px; margin: 0 auto; }
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .faq dt { font-weight: 700; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--ink-3); } .faq a { color: var(--accent); }
    .note { font-size: 13px; color: var(--ink-3); margin-top: 18px; }

    @media (max-width: 760px) {
      .px-text { padding: 0; }
      .crumb { display: none; }
      .px-text h1 { font-size: var(--text-lg); margin: 0 0 8px; }
    }
  </style>
</Base>
