---
import Base from '../layouts/Base.astro';
const title = 'お問い合わせ - numpredo';
const description = 'numpredo へのお問い合わせは contact@numpredo.com まで。ご意見・ご要望、不具合のご報告、著作権に関するお問い合わせを受け付けています。';

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: title,
  description,
  url: 'https://numpredo.com/contact/',
  inLanguage: 'ja',
  mainEntity: { '@id': 'https://numpredo.com/#organization' },
};
---

<Base title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  </Fragment>
  <nav class="crumb"><a href="/">ホーム</a> › お問い合わせ</nav>
  <h1>お問い合わせ</h1>
  <p>numpredo に関するご意見・ご要望、不具合のご報告、著作権・取材などのお問い合わせは、下記のメールアドレスまでお気軽にご連絡ください。</p>

  <h2>メールでのお問い合わせ</h2>
  <p class="mail"><a id="contact-mail-link" href="#contact-mail" data-local="contact" data-domain="numpredo.com" aria-label="contact アットマーク numpredo ドット com"><span>contact</span><span aria-hidden="true">@</span><span>numpredo.com</span></a></p>
  <p class="sub">いただいたお問い合わせには順次対応いたしますが、内容によっては返信までお時間をいただく場合や、返信いたしかねる場合がございます。あらかじめご了承ください。</p>

  <h2>主なお問い合わせ内容</h2>
  <ul>
    <li>問題や解答の誤りのご報告</li>
    <li>サイトの不具合・表示崩れのご報告</li>
    <li>機能のご要望・ご感想</li>
    <li>著作権・コンテンツ利用に関するお問い合わせ（<a href="/terms/">利用規約</a>もあわせてご確認ください）</li>
  </ul>

  <script is:inline>
    // Cloudflare のメール難読化が mailto: を 404 リンクへ書き換えるため、クリック時だけメール URL を組み立てる。
    const mailLink = document.getElementById('contact-mail-link');
    mailLink?.addEventListener('click', (event) => {
      event.preventDefault();
      const { local, domain } = mailLink.dataset;
      if (local && domain) window.location.href = `mailto:${local}@${domain}`;
    });
  </script>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .mail { font-family: var(--font-mincho); font-size: 18px; margin: 6px 0; } .mail a { color: var(--accent); text-decoration: none; }
    .sub { color: var(--ink-3); font-size: 14px; } main ul { line-height: 2; } main ul a { color: var(--accent); }
  </style>
</Base>
