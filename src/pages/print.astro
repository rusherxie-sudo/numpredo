---
import Base from '../layouts/Base.astro';
import ShareBar from '../components/ShareBar.astro';
import { LEVELS } from '../data/levels.ts';
const title = 'ナンプレ・数独 無料プリント問題集（PDF保存）｜numpredo';
const description = 'ナンプレ（数独）を無料でプリント。難易度と問題数を選んで即生成、PDF保存も可。解答付き・唯一解・論理で解ける高品質問題を何度でも印刷できます。';
const url = 'https://numpredo.com/print/';
const faq = [
  { q: 'ナンプレをPDFで保存できますか？', a: 'はい。「生成して印刷」を押すと印刷ダイアログが開きます。プリンターの代わりに「PDFに保存」を選べば、ナンプレ問題をPDFファイルとして保存できます。' },
  { q: '初級だけ・中級だけを印刷できますか？', a: 'できます。難易度ボタンで初級〜超難問を選び、問題数を指定して印刷してください。初級プリントを大量に作って小学生の練習や脳トレに使う方も多いです。' },
  { q: '印刷・プリントは無料ですか？', a: '完全無料・登録不要です。何度でも新しい問題を生成して印刷でき、解答も一緒に印刷されます。' },
];
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' }, { '@type': 'ListItem', position: 2, name: '問題集・印刷', item: url }] };
---

<Base title={title} description={description} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › 問題集・印刷</nav>
  <h1>無料の数独・ナンプレ問題集｜プリント・印刷（PDF保存）</h1>
  <p class="lead">難易度と問題数を選んで「生成して印刷」を押すと、その場で問題を作成し印刷ダイアログが開きます。PDFとして保存も可能。解答付き、すべて唯一解・論理だけで解ける高品質問題です。</p>

  <div id="print-tool" class="print-controls">
    <div class="pc-row">
      <span class="pc-label">難易度</span>
      <div class="chips">
        {LEVELS.map((l) => <button type="button" class={l.slug === 'advanced' ? 'chip on' : 'chip'} data-lv={l.slug}>{l.ja}</button>)}
      </div>
    </div>
    <div class="pc-row">
      <span class="pc-label">問題数</span>
      <div class="chips">
        {[4, 6, 12].map((n) => <button type="button" class={n === 6 ? 'chip on' : 'chip'} data-ct={n}>{n}問</button>)}
      </div>
    </div>
    <label class="pc-check"><input type="checkbox" id="print-cand" /> 候補数字のマスを薄く印刷する</label>
    <button id="print-go" type="button" class="print-go">生成して印刷</button>
    <p id="print-status" class="print-status"></p>
  </div>

  <div id="print-mount" class="print-mount"></div>

  <ShareBar url="https://numpredo.com/print/" title="ナンプレ・数独 無料プリント問題集（PDF保存）｜numpredo" cta="問題集をシェア" />

  <div class="screen-only">
    <h2>ナンプレの印刷・PDF保存について</h2>
    <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>
  </div>

  <h2 class="screen-only">関連</h2>
  <ul class="screen-only">
    <li><a href="/guide/how-to-solve/">解き方ガイド</a></li>
    <li><a href="/daily/">毎日の数独</a></li>
    <li><a href="/play/advanced/">画面でプレイする</a></li>
  </ul>

  <script>
    import '../client/print.ts';
  </script>

  <style is:global>
    .crumb { font-size: 12px; color: var(--sub); margin-bottom: 10px; } .crumb a { color: var(--sub); text-decoration: none; }
    .lead { color: var(--sub); font-size: 14px; margin: 0 0 18px; }
    main ul { line-height: 2; } main ul a { color: var(--ai); }
    .faq dt { font-family: var(--min); font-weight: 600; margin-top: 14px; } .faq dd { margin: 4px 0 0; color: var(--sub); font-size: 14px; } .faq a { color: var(--ai); }

    .print-controls { background: var(--card); border: 1px solid var(--line); border-radius: 9px; padding: 18px; }
    .pc-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
    .pc-label { font-size: 13px; color: var(--sub); min-width: 48px; }
    .chips { display: flex; gap: 6px; flex-wrap: wrap; }
    .chip { font-family: var(--min); font-size: 13px; padding: 5px 13px; border: 1px solid var(--line); border-radius: 4px; background: var(--washi); color: var(--sumi); cursor: pointer; }
    .chip.on { background: var(--shu); color: var(--card); border-color: var(--shu); }
    .pc-check { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--sub); margin: 4px 0 14px; }
    .print-go { background: var(--shu); color: var(--card); border: 0; font-size: 14px; padding: 11px 22px; border-radius: 6px; cursor: pointer; font-family: var(--sans); }
    .print-status { font-size: 13px; color: var(--sub); margin: 10px 0 0; }

    .print-mount { margin-top: 20px; }
    .print-head { display: none; align-items: center; justify-content: space-between; margin-bottom: 12px; font-family: var(--min); }
    .ph-logo b { color: var(--shu); }
    .pz-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .pz figcaption, .az figcaption { font-family: var(--min); font-size: 12px; color: var(--sub); margin-bottom: 5px; }
    .pz svg, .az svg { width: 100%; border: 1px solid var(--line); }
    .answer-page { margin-top: 24px; }
    .answer-page h3 { font-family: var(--min); }
    .az-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

    @media print {
      .site-header, .site-footer, .print-controls, .screen-only, .crumb, h1, .lead { display: none !important; }
      main { max-width: none; padding: 0; }
      body { background: #fff; }
      .print-head { display: flex; }
      .pz { page-break-inside: avoid; }
      .answer-page { page-break-before: always; }
      .pz svg, .az svg { border: 1px solid #ccc; }
    }
    @media (max-width: 560px) { .pz-grid { grid-template-columns: 1fr; } .az-grid { grid-template-columns: repeat(2, 1fr); } }
  </style>
</Base>
