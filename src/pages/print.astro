---
import Base from '../layouts/Base.astro';
import ShareBar from '../components/ShareBar.astro';
import PrintTool from '../components/PrintTool.astro';
const title = '数独・ナンプレ無料印刷｜答え付き問題集・PDF保存（初級〜超難問）- numpredo';
const description = '数独・ナンプレを無料で印刷（プリント）。初級・中級・上級・難問・超難問から難易度と問題数を選んですぐ印刷、解答付きでPDF保存も可能。唯一解・論理だけで解ける検証済みの高品質問題を、自宅やオフィスで何度でも印刷できます。';
const url = 'https://numpredo.com/print/';
const faq = [
  { q: 'ナンプレをPDFで保存できますか？', a: 'はい。「作成して印刷」を押すと印刷ダイアログが開きます。プリンターの代わりに「PDFに保存」を選べば、ナンプレ問題をPDFファイルとして保存できます。' },
  { q: '初級だけ・中級だけを印刷できますか？', a: 'できます。難易度ボタンで初級〜超難問を選び、問題数を指定して印刷してください。初級プリントを大量に作って小学生の練習や脳トレに使う方も多いです。' },
  { q: '印刷・プリントは無料ですか？', a: '完全無料・登録不要です。何度でも問題集を作成して印刷でき、解答も一緒に印刷されます。' },
  { q: 'A4サイズで印刷できますか？', a: 'はい。印刷ダイアログで用紙サイズをA4に設定すれば、1枚にきれいに収まるようレイアウトされます。問題数を選べば、1枚に複数問をまとめて印刷することもできます。' },
  { q: 'まとめて何問も印刷できますか？', a: '問題数（4問・6問・12問）を選んで作成すれば、複数のナンプレを一度に印刷できます。押すたびにランダムな組み合わせになるので、自分だけの問題集のように使えます。' },
  { q: '高齢者向けに大きく印刷したいのですが？', a: '印刷ダイアログの拡大・縮小（倍率）を上げると、マス目を大きく印刷できます。1枚あたりの問題数を少なめ（4問）にすると、さらにゆったり大きく印刷でき、目にやさしくなります。' },
  { q: '数独の問題集として使えますか？', a: '使えます。数百問の検証済み問題プールから押すたびにランダムに組み合わせるので、何度でも刷って問題集として使えます。難易度別にまとめて印刷すれば、自分専用のドリルになります。' },
  { q: '印刷した解答ページをなくしてしまったら？', a: '<a href="/tools/solver/">数独ソルバー（自動解答）</a>にマス目を入力すれば、答えをその場で自動表示できます。写真を撮って読み取らせることもできます。' },
];
const webAppSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: '数独・ナンプレ無料プリント問題集（PDF印刷）', description, url, applicationCategory: 'UtilitiesApplication', operatingSystem: 'Web', inLanguage: 'ja', offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' } };
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })) };

// 難易度別の印刷ガイド（「超難問 印刷」等の難易度×印刷クエリの着地点。h3 に id アンカー、
// 本文の受け皿は難易度別専用ページ /print/[level]/ ——ここからリンクで内部リンク加権）
const printByLevel: Array<{ slug: string; ja: string; h: string; body: string }> = [
  { slug: 'beginner', ja: '初級', h: '初級の数独を印刷する', body: 'ヒントが多く、裸の単数・隠れた単数だけで解ける入門向け。お子さまの練習や、数独がはじめての方のウォーミングアップに。まとめて刷るなら12問がおすすめです。' },
  { slug: 'intermediate', ja: '中級', h: '中級の数独を印刷する', body: '「区画の絞り込み」で一段深く考える定番の歯ごたえ。毎日の脳トレ・通勤のおともにちょうどよい難しさで、繰り返し印刷して日課にするのに向いています。' },
  { slug: 'advanced', ja: '上級', h: '上級の数独を印刷する', body: 'ペア（二国同盟）を使いこなす本格派。候補メモを書き込みながらじっくり解くタイプなので、マス目に書き込める紙との相性が抜群です。' },
  { slug: 'hard', ja: '難問', h: '難問の数独を印刷する', body: '複数のテクニックを組み合わせて解く手強い一問。1枚4問のゆったりレイアウトで印刷して、腰を据えて挑むのがおすすめです。' },
  { slug: 'extreme', ja: '超難問', h: '超難問の数独を印刷する', body: 'スカイスクレイパー・X-Wing級の最難関。超難問のナンプレを無料で印刷できるサイトは少なく、しかも全問が唯一解・論理だけで解けることを検証済み。上級者の挑戦用にどうぞ。' },
];
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' }, { '@type': 'ListItem', position: 2, name: '問題集・印刷', item: url }] };
const howToSchema = {
  '@context': 'https://schema.org', '@type': 'HowTo',
  name: '数独・ナンプレを無料で印刷（PDF保存）する方法',
  description: '難易度と問題数を選ぶだけで、検証済みの数独・ナンプレ問題集を無料で印刷、またはPDFとして保存する手順。',
  inLanguage: 'ja', totalTime: 'PT1M',
  step: [
    { '@type': 'HowToStep', position: 1, name: '難易度と問題数を選ぶ', text: '初級〜超難問から難易度を選び、1枚に入れる問題数（4問・6問・12問）を指定します。' },
    { '@type': 'HowToStep', position: 2, name: '「作成して印刷」を押す', text: '数百問の検証済みプールからランダムに問題集を組み立て、印刷ダイアログが開きます。解答も一緒に印刷されます。' },
    { '@type': 'HowToStep', position: 3, name: '印刷またはPDFに保存', text: 'プリンターで印刷するか、「PDFに保存」を選べばPDFファイルとして保存できます。用紙サイズはA4がおすすめです。', url: url },
  ],
};
---

<Base title={title} description={description} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › 問題集・印刷</nav>
  <h1>無料の数独・ナンプレ問題集｜答え付きプリント・印刷（PDF保存）</h1>
  <p class="lead">難易度と問題数を選んで「作成して印刷」を押すと、検証済みの問題プールからランダムに問題集を組み立てて、印刷ダイアログが開きます。PDFとして保存も可能。解答付き、すべて唯一解・論理だけで解ける高品質問題です。</p>

  <PrintTool />

  <ShareBar url="https://numpredo.com/print/" title="ナンプレ・数独 無料プリント問題集（PDF保存）｜numpredo" cta="問題集をシェア" />

  <div class="screen-only">
    <h2>紙に印刷して数独を解くメリット</h2>
    <p>画面で解くのと違い、紙のナンプレは<strong>鉛筆で候補を書き込みながらじっくり考えられる</strong>のが魅力です。目が疲れにくく、電源やネット環境も不要。脳トレや待ち時間の暇つぶし、家族みんなで楽しむのにも向いています。解答も一緒に印刷されるので、解き終わったその場で答え合わせができます。</p>

    <h2>こんな使い方に</h2>
    <ul>
      <li><strong>高齢者の脳トレに。</strong>マス目を大きめに印刷でき、繰り返し解いて<a href="/guide/brain-training/">脳の活性化</a>に役立てる方が多いです。</li>
      <li><strong>子どもの学習に。</strong>初級をまとめて印刷すれば、数字と論理的思考の練習になります。さらにやさしい<a href="/variants/6x6/">6×6数独</a>から始めるのもおすすめです。</li>
      <li><strong>旅行・通院の持ち歩きに。</strong>PDFに保存しておけば、コンビニ印刷やタブレット表示にも使えます。</li>
    </ul>

    <h2>難易度の選び方</h2>
    <p>はじめての方や答え合わせ用なら<strong>初級・中級</strong>、歯ごたえが欲しい方は<strong>上級〜超難問</strong>がおすすめです。すべて唯一解・論理だけで解けるので、印刷した問題は当てずっぽうなしで必ず解けます。難易度ごとの特徴は<a href="/play/">プレイ一覧</a>で確認できます。</p>

    <h2>難易度別に印刷する（初級〜超難問）</h2>
    <p>ページ上部の難易度ボタンで選んで「作成して印刷」を押すだけ。難易度ごとの専用ページでは、その難易度の特徴・おすすめの刷り方・よくある質問もまとめています。</p>
    {printByLevel.map((x) => (
      <>
        <h3 id={x.slug}>{x.h}</h3>
        <p>{x.body}</p>
        <p class="plv-go"><a href={`/print/${x.slug}/`}>{x.ja}の印刷専用ページへ（おすすめの刷り方・FAQ）→</a></p>
      </>
    ))}

    <h2>ナンプレをPDFでダウンロード・保存する方法</h2>
    <p>プリンターがなくてもPDFで保存できます。「作成して印刷」を押して印刷ダイアログが開いたら、プリンターの代わりに「<strong>PDFに保存</strong>」を選ぶだけ。スマホやタブレットに数独・ナンプレのPDFを保存しておけば、コンビニ印刷やあとで解く用に使えます。<strong>数独・ナンプレのPDF無料ダウンロード</strong>としてもお使いください。用紙はA4がおすすめです。</p>

    <h2>毎回ちがう組み合わせで刷れる｜固定の問題集との違い</h2>
    <p>市販の数独問題集は<strong>ページ順に解き進めるだけ</strong>ですが、numpredo のプリントは<strong>数百問の検証済み問題プールから、押すたびにランダムな組み合わせ</strong>で問題集を作ります。何度でも・何枚でも刷れるので、家族で同じ難易度を別々に解いたり、毎日ちがう一枚を続けたりと、自分だけの問題集として使えます。</p>
    <p>「数独の問題をまとめて印刷したい」「無料で数独プリントを大量に用意したい」というときにも便利です。収録されている問題はすべて唯一解・論理だけで解けることを機械検証済みで、難易度ラベルも正確。解答も一緒に印刷されます。</p>
  </div>

  <div class="screen-only">
    <h2>ナンプレの印刷・PDF保存について</h2>
    <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>
  </div>

  <h2 class="screen-only">関連</h2>
  <ul class="screen-only">
    <li><a href="/guide/how-to-solve/">解き方ガイド</a></li>
    <li><a href="/daily/">毎日の数独</a></li>
    <li><a href="/play/advanced/">画面でプレイする</a></li>
    <li><a href="/tools/solver/">自動解答ソルバーで答え合わせ</a></li>
  </ul>

  <style is:global>
    /* 印刷ツール本体・@media print のスタイルは PrintTool.astro に集約（難易度別ページと共用） */
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 18px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .faq dt { font-family: var(--font-mincho); font-weight: 600; margin-top: 14px; } .faq dd { margin: 4px 0 0; color: var(--ink-3); font-size: 14px; } .faq a { color: var(--accent); }
  </style>
</Base>
