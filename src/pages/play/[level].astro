---
import Base from '../../layouts/Base.astro';
import ShareBar from '../../components/ShareBar.astro';
import SudokuGame from '../../components/SudokuGame.astro';
import { LEVELS, type LevelMeta } from '../../data/levels.ts';
import { TECHNIQUES } from '../../data/techniques.ts';
import { renderBoardSvg, gridFromString, traceFirstElimination, TOKEN_THEME } from '../../engine/index.ts';

// 各難易度で習得すべき具体テクニック → 技巧攻略ページへ内部リンク
const LEVEL_TECHS: Record<string, string[]> = {
  beginner: ['naked-pair'],
  intermediate: ['pointing', 'naked-pair'],
  advanced: ['naked-pair', 'hidden-pair', 'pointing'],
  hard: ['naked-triple', 'skyscraper', 'x-wing'],
  extreme: ['x-wing', 'swordfish', 'skyscraper'],
};

export function getStaticPaths() {
  return LEVELS.map((meta) => ({ params: { level: meta.slug }, props: { meta } }));
}

interface Props {
  meta: LevelMeta;
}
const { meta } = Astro.props;
const techLinks = (LEVEL_TECHS[meta.slug] ?? [])
  .map((s) => TECHNIQUES.find((t) => t.slug === s))
  .filter((t): t is (typeof TECHNIQUES)[number] => Boolean(t));

const title = `${meta.ja}の数独・ナンプレを無料でプレイ｜numpredo`;
const description = meta.metaDesc;
const url = `https://numpredo.com/play/${meta.slug}/`;

const others = LEVELS.filter((l) => l.slug !== meta.slug);

// 构建期 SVG 图解（题面 + 引擎真实推理の消去）→ 内容丰富度 + image pack
const sample = gridFromString(meta.puzzles[0].puzzle);
const givenMask = sample.map((v) => v !== 0);
const svgPuzzle = renderBoardSvg(sample, { given: givenMask, theme: TOKEN_THEME, cell: 36, title: `${meta.ja}の数独・ナンプレ問題例`, desc: `${meta.ja}の問題例` });
const trace = traceFirstElimination(sample);
let svgTech = '';
if (trace) {
  const marks = (trace.step.eliminations ?? []).map(([cell, digit]) => ({ cell, digit, type: 'eliminate' as const }));
  const hl = [...new Set((trace.step.eliminations ?? []).map(([c]) => c))].map((cell) => ({ cell }));
  svgTech = renderBoardSvg(trace.grid, { given: givenMask, candidates: trace.candidates, cellHighlights: hl, candidateMarks: marks, theme: TOKEN_THEME, cell: 36, title: `${meta.ja}のテクニック例`, desc: '候補消去の例' });
}

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${meta.ja}ナンプレ（数独）`,
  description,
  url,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web',
  inLanguage: 'ja',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
};
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: meta.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'プレイ', item: 'https://numpredo.com/play/' },
    { '@type': 'ListItem', position: 3, name: meta.ja, item: url },
  ],
};
---

<Base title={title} description={description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="px-text">
    <nav class="crumb"><a href="/">ホーム</a> › <a href="/play/">プレイ</a> › {meta.ja}</nav>

    <h1>{meta.ja}の数独・ナンプレ</h1>

    <div class="diff-badges">
      {LEVELS.map((l) => <a href={`/play/${l.slug}/`} class={l.slug === meta.slug ? 'diff-bdg on' : 'diff-bdg'}>{l.ja}</a>)}
    </div>
  </div>

  {/* 嵌入 30 道 = 图解页 No.1〜30（SETS_PER_LEVEL，改时同步）：「別の問題」池内循环 + ?n= 直达，不做客户端实时生成 */}
<SudokuGame level={meta.slug} levelJa={meta.ja} url={url} set={meta.puzzles.slice(0, 30).map((p) => ({ puzzle: p.puzzle, solution: p.solution }))} />

  <div class="px-text">
    <p class="lead">{meta.lead}</p>
    <ShareBar url={url} title={title} cta="この問題をシェア・友達に挑戦状を送ろう" />

  <h2>{meta.ja}で必要なテクニック</h2>
  <p>{meta.technique}</p>
  {techLinks.length > 0 && (
    <ul class="tech-links">
      {techLinks.map((t) => (<li><a href={`/guide/techniques/${t.slug}/`}>{t.name}の解き方（図解）</a></li>))}
    </ul>
  )}
  <div class="fig-row">
    <figure class="guide-fig"><Fragment set:html={svgPuzzle} /><figcaption>{meta.ja}の問題例（太字がヒント）</figcaption></figure>
    {svgTech && <figure class="guide-fig"><Fragment set:html={svgTech} /><figcaption>候補消去の例（赤い候補が消える）</figcaption></figure>}
  </div>

  <h2>{meta.ja}攻略のコツ</h2>
  <ul>{meta.tips.map((t) => <li>{t}</li>)}</ul>

  <h2>解き方をもっと学ぶ</h2>
  <p>
    テクニックの図解は<a href="/guide/how-to-solve/">数独・ナンプレの解き方ガイド</a>で詳しく解説しています。
    ルールから確認したい方は<a href="/guide/rules/">ルール・遊び方</a>へ。
  </p>

  <h2>{meta.ja}の問題集・一手ずつ図解</h2>
  <p>{meta.ja}の問題を、解答エンジンの手順どおりに一手ずつ図解で解説しています。詰まったときの「次の一手」の参考にどうぞ。</p>
  <ul class="setlist">{Array.from({ length: Math.min(30, meta.puzzles.length) }, (_, i) => i + 1).map((i) => <li><a href={`/play/${meta.slug}/${i}/`}>数独{meta.ja} No.{i} の解き方図解</a></li>)}</ul>

  <h2>他の難易度で遊ぶ</h2>
  <ul>{others.map((l) => <li><a href={`/play/${l.slug}/`}>{l.ja}（{l.en}）</a></li>)}</ul>

  <h2>印刷して解く</h2>
  <p>紙で解きたい方は<a href="/print/">無料の数独・ナンプレ問題集（PDF印刷）</a>へ。難易度・問題数を選んでダウンロードできます。</p>

  <h2>よくある質問</h2>
  <dl class="faq">{meta.faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>
  </div>

  <style is:global>
    .px-text { max-width: 1060px; margin: 0 auto; }
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; }
    .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    .faq dt { font-family: var(--font-mincho); font-weight: 600; margin-top: 16px; }
    .faq dd { margin: 5px 0 0; color: var(--ink-3); }
    main ul { line-height: 2; }
    main ul a { color: var(--accent); }
    .setlist { columns: 3; column-gap: 24px; }
    .setlist li { break-inside: avoid; }
    @media (max-width: 760px) { .setlist { columns: 2; } }

    .fig-row { display: flex; gap: 14px; flex-wrap: wrap; margin: 14px 0; }
    .guide-fig { flex: 1 1 240px; margin: 0; text-align: center; }
    .guide-fig svg { width: 100%; max-width: 320px; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    .guide-fig figcaption { font-size: 12px; color: var(--ink-3); margin-top: 6px; }
    .diff-badges { display: flex; gap: 7px; flex-wrap: wrap; margin: 0 0 18px; }
    .diff-bdg { font-family: var(--font-mincho); font-size: 14px; padding: 4px 14px; border: 1px solid var(--accent); color: var(--accent); border-radius: 3px; text-decoration: none; }
    .diff-bdg.on { background: var(--accent); color: var(--surface); }

    @media (max-width: 760px) {
      .px-text { padding: 0; }
      .crumb { display: none; }
      .px-text h1 { font-size: var(--text-lg); margin: 0 0 8px; }
      .diff-badges { flex-wrap: nowrap; overflow-x: auto; -webkit-overflow-scrolling: touch; padding-bottom: 4px; margin-bottom: 12px; }
      .diff-bdg { white-space: nowrap; flex: 0 0 auto; }
      .fig-row { gap: 10px; }
    }
  </style>
</Base>
