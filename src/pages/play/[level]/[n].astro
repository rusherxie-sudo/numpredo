---
import Base from '../../../layouts/Base.astro';
import ShareBar from '../../../components/ShareBar.astro';
import { LEVELS, type LevelMeta } from '../../../data/levels.ts';
import { renderBoardSvg, gridFromString, logicalSolve, traceKeySteps, renderStepFigures, TECH_INFO, TOKEN_THEME } from '../../../engine/index.ts';
import lastmodJson from '../../../data/sitemap-lastmod.json';
import publishedJson from '../../../data/published.json';
const lastmod: Record<string, string> = lastmodJson;
const published: Record<string, string> = publishedJson;

export function getStaticPaths() {
  // 新規 URL を日付だけで増やさず、既存 90 問のクロール・評価を先に完了させる。
  const cap = 90;
  return LEVELS.flatMap((meta) =>
    Array.from({ length: Math.min(cap, meta.puzzles.length) }, (_, i) => i + 1).map((n) => ({
      params: { level: meta.slug, n: String(n) },
      props: { meta, n, setsPerLevel: cap },
    })),
  );
}

interface Props {
  meta: LevelMeta;
  n: number;
  setsPerLevel: number;
}
const { meta, n, setsPerLevel } = Astro.props;
const SETS_PER_LEVEL = setsPerLevel;
const puzzle = meta.puzzles[n - 1];
const url = `https://numpredo.com/play/${meta.slug}/${n}/`;

const grid = gridFromString(puzzle.puzzle);
const given = grid.map((v) => v !== 0);
const sol = logicalSolve(gridFromString(puzzle.puzzle));
const keySteps = traceKeySteps(gridFromString(puzzle.puzzle));
const clues = grid.filter((v) => v !== 0).length;
const hardest = sol.hardest ?? 'nakedSingle';
const hardestInfo = TECH_INFO[hardest] ?? TECH_INFO.nakedSingle;

// 題面 SVG
const svgPuzzle = renderBoardSvg(grid, { given, theme: TOKEN_THEME, cell: 34, title: `数独${meta.ja} No.${n}の問題`, desc: `${meta.ja}の問題例` });

// 各キーステップの図解 SVG + 説明（engine の共通関数で生成）
const stepFigs = renderStepFigures(keySteps, given);

// 他の問題（同档相邻 ±6 を内部リンク。全件は档主页=枢纽が列挙、ここは近隣のみで過剰リンク回避）
const sameLevelNs = Array.from({ length: Math.min(SETS_PER_LEVEL, meta.puzzles.length) }, (_, i) => i + 1).filter((x) => x !== n && Math.abs(x - n) <= 6);
const otherLevels = LEVELS.filter((l) => l.slug !== meta.slug);

// ページ固有の実測パラメータ（description/本文の差別化：同档で clues/hardest が定数に潰れる档＝初級でも毎題変わる）
const hiddenN = sol.steps.filter((s) => s.technique === 'hiddenSingle').length;
const firstCell = sol.steps.find((s) => s.cell !== undefined)?.cell;
const firstPos = firstCell !== undefined ? `${Math.floor(firstCell / 9) + 1}行${(firstCell % 9) + 1}列` : '';

const title = `数独${meta.ja} No.${n}｜一手ずつ図解で解き方 - numpredo`;
const description = `数独（ナンプレ）${meta.ja}の問題 No.${n}を一手ずつ図解で解説。ヒント${clues}個・全${sol.steps.length}手${hiddenN > 0 ? `（隠れた単数${hiddenN}回）` : ''}、最難テクニックは${hardestInfo.ja}${firstPos ? `。最初の一手は${firstPos}から` : ''}。当てずっぽうなしで解ける手順を盤面付きで。`;
const h1 = `数独${meta.ja} No.${n}｜一手ずつ図解で解き方`;

// FAQ 第2・3問は3套措辞按 n%3 轮换：同档30页逐字相同の定型文が FAQPage JSON-LD で並ぶのを避ける
// （第1問は clues/手数/最難技巧が入るため元々ページ固有）
const faqStuck = [
  `まず全空きマスに候補をメモしましょう。それでも詰まったら、このページの「一手ずつ図解」で${hardestInfo.ja}の使いどころを確認してください。`,
  `候補のメモを最新の状態に整えるのが先決です。行き詰まったら、図解の該当手順まで進めて、${hardestInfo.ja}をどこで使うかを見比べてみてください。`,
  `詰まったときは、消せる候補の見落としがないかを疑いましょう。このページの図解で、${hardestInfo.ja}が登場する場面を確認するのが近道です。`,
];
const faqStuckLink = hardestInfo.slug
  ? `くわしくは<a href="/guide/techniques/${hardestInfo.slug}/">${hardestInfo.ja}の解き方</a>へ。`
  : '基本は<a href="/guide/beginner/">単数の見つけ方</a>で解けます。';
const faqNoGuess = [
  'はい。当サイトの問題はすべて「解が一つだけ」「論理だけで解ける」ことを検証済みです。図解の手順どおりに進めれば、必ず次の一手が見つかります。',
  `はい。この問題は機械検証で唯一解・論理のみで解けることを確認済みです。全${sol.steps.length}手のどこにも当てずっぽうは登場しません。`,
  'はい。仮置き（トライ＆エラー）は一切不要です。掲載している図解も、実際に論理だけで解いた手順をそのまま示しています。',
];
const faq = [
  { q: `この数独${meta.ja} No.${n}の難易度は？`, a: `ヒント（最初から入っている数字）は${clues}個、論理だけで解ける手数は全${sol.steps.length}手です。この問題を解くカギは「${hardestInfo.ja}」。当てずっぽうなしで、図解の手順どおりに進めれば必ず解けます。` },
  { q: '解けないときはどうすればいい？', a: `${faqStuck[n % 3]}${faqStuckLink}` },
  { q: 'この問題は当てずっぽうなしで解けますか？', a: faqNoGuess[n % 3] },
];

const datePublished = published[`/play/${meta.slug}/${n}/`];
// 防御性钳制：扩容直后 sitemap-lastmod 未重跑时可能出现 modified < published 的非法时序
const rawModified = lastmod[`/play/${meta.slug}/${n}/`];
const dateModified = rawModified && datePublished && rawModified < datePublished ? datePublished : rawModified;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1,
  description,
  inLanguage: 'ja',
  mainEntityOfPage: url,
  image: 'https://numpredo.com/og-image.png',
  author: { '@id': 'https://numpredo.com/#organization' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
};
const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `数独${meta.ja} No.${n}の解き方`,
  description: `数独${meta.ja} No.${n}を論理だけで解く手順`,
  inLanguage: 'ja',
  step: stepFigs.map((f, i) => ({ '@type': 'HowToStep', position: i + 1, name: f.label, text: f.text })),
};
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'プレイ', item: 'https://numpredo.com/play/' },
    { '@type': 'ListItem', position: 3, name: meta.ja, item: `https://numpredo.com/play/${meta.slug}/` },
    { '@type': 'ListItem', position: 4, name: `No.${n}`, item: url },
  ],
};
---

<Base title={title} description={description} canonical={url}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › <a href="/play/">プレイ</a> › <a href={`/play/${meta.slug}/`}>{meta.ja}</a> › No.{n}</nav>
  <h1>{h1}</h1>
  <p class="lead">数独（ナンプレ）<strong>{meta.ja}</strong>の問題 No.{n} を、論理だけで解いた手順で一手ずつ図解します。ヒント<strong>{clues}個</strong>、最難テクニックは<strong>{hardestInfo.ja}</strong>。すべて当てずっぽうなしで解けます。</p>

  <figure class="pz-fig"><Fragment set:html={svgPuzzle} /><figcaption>数独{meta.ja} No.{n} の問題（太字がヒント）</figcaption></figure>

  <h2>この問題の特徴</h2>
  <ul class="feat">
    <li>ヒントの数：<strong>{clues}個</strong></li>
    <li>最難テクニック：<strong>{hardestInfo.ja}</strong></li>
    <li>論理で解ける手数：<strong>全{sol.steps.length}手</strong>{hiddenN > 0 && <>（うち隠れた単数 {hiddenN} 回）</>}</li>
    {firstPos && <li>最初に確定できるマス：<strong>{firstPos}</strong></li>}
  </ul>

  <h2>一手ずつ図解で解いてみよう</h2>
  <p>裸の単数で埋まるところから、難しい一手（{hardestInfo.ja}）まで、解答エンジンが実際に解いた推理を順番に図解します。各図の<strong>赤い候補が消える数字</strong>、<strong>枠つきのマス</strong>が注目点です。</p>
  <div class="steps">
    {stepFigs.map((f) => (
      <figure class="step-fig">
        <Fragment set:html={f.svg} />
        <figcaption><strong>{f.label}</strong>{f.slug ? <> ・ <a href={`/guide/techniques/${f.slug}/`}>くわしい解き方</a></> : null}</figcaption>
        <p set:html={f.text} />
      </figure>
    ))}
  </div>

  <h2>つまずいたら</h2>
  <p set:html={hardestInfo.slug
    ? `この問題の山場は<a href="/guide/techniques/${hardestInfo.slug}/">${hardestInfo.ja}</a>です。使い方をくわしく確認してから戻ると、自力で解けるようになります。全体の手順は<a href="/guide/how-to-solve/">解き方完全ガイド</a>に。`
    : `${meta.ja}は<a href="/guide/beginner/">単数の見つけ方</a>だけで解けます。手順全体は<a href="/guide/how-to-solve/">解き方完全ガイド</a>へ。`} />

  <ShareBar url={url} title={title} cta="この図解が役に立ったらシェア" />

  <h2>遊ぶ・印刷する</h2>
  <ul>
    <li><a href={`/play/${meta.slug}/?n=${n}`}>この問題（No.{n}）を画面でプレイ</a></li>
    <li><a href={`/play/${meta.slug}/`}>同じ難易度（{meta.ja}）を画面でプレイ</a></li>
    <li><a href="/print/">無料プリントで{meta.ja}を印刷</a></li>
  </ul>

  <h2>他の{meta.ja}の問題</h2>
  <ul class="numlist">
    {sameLevelNs.map((x) => <li><a href={`/play/${meta.slug}/${x}/`}>数独{meta.ja} No.{x}</a></li>)}
  </ul>

  <h2>他の難易度の図解</h2>
  <ul class="numlist">
    {otherLevels.map((l) => <li><a href={`/play/${l.slug}/${n}/`}>数独{l.ja} No.{n}</a></li>)}
  </ul>

  <h2>よくある質問</h2>
  <dl class="faq">{faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    main ul { line-height: 1.9; } main ul a, main p a { color: var(--accent); }
    .faq dt { font-family: var(--font-mincho); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--ink-3); }
    .pz-fig { margin: 14px auto; text-align: center; max-width: 320px; }
    .pz-fig svg, .step-fig svg { width: 100%; border: 1px solid var(--line); border-radius: 8px; background: var(--surface); }
    .pz-fig figcaption, .step-fig figcaption { font-size: 12px; color: var(--ink-3); margin-top: 6px; }
    .feat { list-style: none; padding: 0; display: flex; flex-wrap: wrap; gap: 8px 20px; }
    .feat li { font-size: 14px; color: var(--ink-2); }
    .steps { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 16px; margin: 14px 0; }
    .step-fig { margin: 0; }
    .step-fig p { font-size: 13px; color: var(--ink-3); margin: 6px 0 0; line-height: 1.6; }
    .numlist { columns: 2; }
    @media (max-width: 560px) { .steps { grid-template-columns: 1fr; } .numlist { columns: 1; } }
  </style>
</Base>
