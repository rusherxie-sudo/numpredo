---
import Base from '../../layouts/Base.astro';
import { LEVELS } from '../../data/levels.ts';
const title = '数独・ナンプレを無料でプレイ｜難易度一覧 - numpredo';
const description = '初級から超難問まで、無料の数独（ナンプレ）を難易度別にプレイ。すべて唯一解・論理だけで解ける高品質問題。登録不要、スマホ対応。';
const url = 'https://numpredo.com/play/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'プレイ', item: url },
  ],
};
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '数独・ナンプレの難易度一覧',
  itemListElement: LEVELS.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${l.ja}の数独・ナンプレ`,
    url: `https://numpredo.com/play/${l.slug}/`,
  })),
};
---

<Base title={title} description={description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › プレイ</nav>
  <h1>数独・ナンプレを無料でプレイ</h1>
  <p class="lead">難易度を選んでプレイ。すべて唯一解・論理だけで解ける高品質問題です。</p>

  <div class="play-list">
    {LEVELS.map((l) => (
      <a href={`/play/${l.slug}/`} class="play-card">
        <span class="pc-j">{l.ja}<span class="pc-e">（{l.en}）</span></span>
        <span class="pc-d">{l.lead}</span>
      </a>
    ))}
  </div>

  <h2>問題集・一手ずつ図解で解き方</h2>
  <p class="lead">各難易度の問題を、解答エンジンの手順どおりに一手ずつ図解。詰まったときの「次の一手」と、その難易度で使うテクニックがわかります。</p>
  <ul>
    {LEVELS.map((l) => <li><a href={`/play/${l.slug}/1/`}>数独{l.ja}の問題を図解で解く（No.1〜12）</a></li>)}
  </ul>

  <h2>バリエーション数独</h2>
  <ul>
    <li><a href="/variants/killer/">キラー数独</a> — ケージの合計から解く</li>
    <li><a href="/variants/6x6/">6×6数独（ミニ数独）</a> — 1〜6だけの入門向け</li>
    <li><a href="/variants/inequality/">不等号ナンプレ</a> — 大小関係で絞り込む</li>
    <li><a href="/variants/diagonal/">対角線数独（X数独）</a> — 対角線にも1〜9を入れる【プレイできます】</li>
  </ul>

  <h2>学ぶ・印刷する</h2>
  <ul>
    <li><a href="/guide/how-to-solve/">数独・ナンプレの解き方ガイド</a></li>
    <li><a href="/print/">無料PDF問題集（印刷）</a></li>
    <li><a href="/daily/">毎日の数独</a></li>
  </ul>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; }
    .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 18px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .play-list { display: flex; flex-direction: column; gap: 10px; }
    .play-card { display: block; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 16px 18px; text-decoration: none; color: var(--ink); transition: border-color 0.12s; }
    .play-card:hover { border-color: var(--accent); }
    .pc-j { font-family: var(--font-mincho); font-size: 17px; font-weight: 600; }
    .pc-e { font-size: 12px; color: var(--ink-3); font-weight: 400; }
    .pc-d { display: block; font-size: 13px; color: var(--ink-3); margin-top: 4px; }
  </style>
</Base>
