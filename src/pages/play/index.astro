---
import Base from '../../layouts/Base.astro';
import { LEVELS } from '../../data/levels.ts';
// 収録総数は題庫から実測（「問題集」系クエリの受け皿：数字は本物、扩库自動追随）
const totalPuzzles = LEVELS.reduce((s, l) => s + l.puzzles.length, 0);
const title = `数独・ナンプレ無料問題集｜全${totalPuzzles}問を難易度別にプレイ - numpredo`;
const description = `初級から超難問まで全${totalPuzzles}問収録の無料数独（ナンプレ）問題集。難易度別にオンラインでプレイでき、すべて唯一解・論理だけで解ける検証済みの高品質問題。図解つき解説・印刷にも対応、登録不要でスマホでも遊べます。`;
const url = 'https://numpredo.com/play/';

// 難易度比較表：ヒント数は題庫全量から実測平均（構築期に計算、データと乖離しない）
const SETS = 55; // = play/[level]/[n].astro の SETS_PER_LEVEL（同期点）
const SHORT_TECH: Record<string, string> = {
  beginner: '裸の単数・隠れた単数',
  intermediate: '区画の絞り込み',
  advanced: 'ペア（二国同盟）',
  hard: '三国同盟（ネイキッドトリプル）',
  extreme: 'スカイスクレイパー・X-Wingなど',
};
// 空マスは題庫 JSON で '.'（gridToString 出力）——数字だけを数える（'0' 表記にも頑健）
const avgClues = (puzzles: Array<{ puzzle: string }>): number =>
  Math.round(puzzles.reduce((s, p) => s + [...p.puzzle].filter((c) => c >= '1' && c <= '9').length, 0) / puzzles.length);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'プレイ', item: url },
  ],
};
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: '数独・ナンプレの難易度一覧',
  itemListElement: LEVELS.map((l, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${l.ja}の数独・ナンプレ`,
    url: `https://numpredo.com/play/${l.slug}/`,
  })),
};
---

<Base title={title} description={description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  </Fragment>

  <nav class="crumb"><a href="/">ホーム</a> › プレイ</nav>
  <h1>数独・ナンプレ無料問題集｜難易度別にプレイ</h1>
  <p class="lead">初級から超難問まで全{totalPuzzles}問を収録。難易度を選んでプレイ、すべて唯一解・論理だけで解ける高品質問題です。</p>

  <div class="play-list">
    {LEVELS.map((l) => (
      <a href={`/play/${l.slug}/`} class="play-card">
        <span class="pc-j">{l.ja}<span class="pc-e">（{l.en}）</span></span>
        <span class="pc-d">{l.lead}</span>
      </a>
    ))}
  </div>

  <h2>難易度の比較（早見表）</h2>
  <p class="lead">どの難易度から始めるか迷ったら。必要なテクニックとヒント数のめやすで選べます。</p>
  <div class="gtable-wrap">
    <table class="gtable">
      <thead><tr><th>難易度</th><th>解くのに必要な主なテクニック</th><th>ヒント数（平均）</th><th>収録問題数</th></tr></thead>
      <tbody>
        {LEVELS.map((l) => (
          <tr>
            <td><a href={`/play/${l.slug}/`}>{l.ja}（{l.en}）</a></td>
            <td>{SHORT_TECH[l.slug]}</td>
            <td>約{avgClues(l.puzzles)}個</td>
            <td>{l.puzzles.length}問</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="tnote">※ ブラウザでの出題は各難易度55問を順繰りに、<a href="/print/">印刷ページ</a>では収録全問からランダムに出題します。</p>

  <h2>問題集・一手ずつ図解で解き方</h2>
  <p class="lead">各難易度の問題を、解答エンジンの手順どおりに一手ずつ図解。詰まったときの「次の一手」と、その難易度で使うテクニックがわかります。</p>
  <ul>
    {LEVELS.map((l) => <li><a href={`/play/${l.slug}/1/`}>数独{l.ja}の問題を図解で解く（No.1〜{SETS}）</a></li>)}
  </ul>

  <h2>バリエーション数独</h2>
  <ul>
    <li><a href="/variants/killer/">キラー数独</a> — ケージの合計から解く【プレイできます】</li>
    <li><a href="/variants/6x6/">6×6数独（ミニ数独）</a> — 1〜6だけの入門向け</li>
    <li><a href="/variants/inequality/">不等号ナンプレ</a> — 大小関係で絞り込む</li>
    <li><a href="/variants/diagonal/">対角線数独（X数独）</a> — 対角線にも1〜9を入れる【プレイできます】</li>
  </ul>

  <h2>学ぶ・印刷する</h2>
  <ul>
    <li><a href="/guide/how-to-solve/">数独・ナンプレの解き方ガイド</a></li>
    <li><a href="/print/">無料PDF問題集（印刷）</a></li>
    <li><a href="/daily/">毎日の数独</a></li>
  </ul>

  <style is:global>
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; }
    .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 18px; }
    main ul { line-height: 2; } main ul a { color: var(--accent); }
    .play-list { display: flex; flex-direction: column; gap: 10px; }
    .play-card { display: block; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 16px 18px; text-decoration: none; color: var(--ink); transition: border-color 0.12s; }
    .play-card:hover { border-color: var(--accent); }
    .pc-j { font-family: var(--font-mincho); font-size: 17px; font-weight: 600; }
    .pc-e { font-size: 12px; color: var(--ink-3); font-weight: 400; }
    .pc-d { display: block; font-size: 13px; color: var(--ink-3); margin-top: 4px; }
    .gtable-wrap { overflow-x: auto; margin: 10px 0 4px; }
    .gtable { width: 100%; border-collapse: collapse; font-size: 14px; }
    .gtable th, .gtable td { border: 1px solid var(--line-2); padding: 8px 11px; text-align: left; vertical-align: top; }
    .gtable th { background: var(--surface-2); font-weight: 700; color: var(--ink); }
    .gtable td:first-child { white-space: nowrap; }
    .tnote { font-size: 12px; color: var(--ink-4); margin: 6px 0 0; }
  </style>
</Base>
