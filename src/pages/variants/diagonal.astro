---
// 対角線数独（X数独）可玩页。数据仍取自 variants.ts 的 diagonal 条目（单一数据源），
// 但走独立静态路由而非 [slug].astro：Astro 的 hoisted script 在条件渲染下也会打包，
// 混在动态路由会让 killer/6x6/不等号页背上游戏 JS（违反内容页零 JS）。
import Base from '../../layouts/Base.astro';
import ShareBar from '../../components/ShareBar.astro';
import SudokuGame from '../../components/SudokuGame.astro';
import { VARIANTS, variantBySlug } from '../../data/variants.ts';
import diagonalPack from '../../data/puzzles/diagonal.json';
import lastmodJson from '../../data/sitemap-lastmod.json';
import publishedJson from '../../data/published.json';

const lastmod: Record<string, string> = lastmodJson;
const published: Record<string, string> = publishedJson;

const v = variantBySlug('diagonal')!;
const url = 'https://numpredo.com/variants/diagonal/';
const others = VARIANTS.filter((x) => x.slug !== v.slug);
// 全 30 问嵌入（易→难顺，「別の問題」池内循环；与 gen-pool 的排序约定一致）
const set = diagonalPack.puzzles.map((p) => ({ puzzle: p.puzzle, solution: p.solution }));

// 可玩页 = WebApplication（play/[level] 范式）＋ 解説長文としての Article/FAQ/Breadcrumb を維持
const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: '対角線数独（X数独）',
  description: v.description,
  url,
  applicationCategory: 'GameApplication',
  operatingSystem: 'Web',
  inLanguage: 'ja',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'JPY' },
};
const datePublished = published['/variants/diagonal/'];
const dateModified = lastmod['/variants/diagonal/'];
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: v.h1,
  description: v.description,
  inLanguage: 'ja',
  mainEntityOfPage: url,
  image: 'https://numpredo.com/og-image.png',
  author: { '@id': 'https://numpredo.com/#organization' },
  publisher: { '@id': 'https://numpredo.com/#organization' },
  speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.lead', '.faq'] },
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
};
// JSON-LD 内リンクは絶対 URL に（ページ文脈から切り離して消費されても辿れるように）
const abs = (h: string): string => h.replace(/href="\//g, 'href="https://numpredo.com/');
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: v.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: abs(f.a) } })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://numpredo.com/' },
    { '@type': 'ListItem', position: 2, name: 'プレイ', item: 'https://numpredo.com/play/' },
    { '@type': 'ListItem', position: 3, name: v.name, item: url },
  ],
};
---

<Base title={v.title} description={v.description} canonical={url} wide>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="px-text">
    <nav class="crumb"><a href="/">ホーム</a> › <a href="/play/">プレイ</a> › {v.name}</nav>
    <h1>{v.h1}</h1>
    {dateModified && <p class="upd"><time datetime={dateModified}>最終更新日：{dateModified.slice(0, 10).replace(/-/g, '/')}</time></p>}
    <p class="lead">{v.lead}</p>
  </div>

  <SudokuGame level="diagonal" levelJa="対角線数独" url={url} variant="diagonal" set={set} />

  <div class="px-text">
    <ShareBar url={url} title={v.title} cta="この問題をシェア・友達に挑戦状を送ろう" />

    <figure class="var-fig"><Fragment set:html={v.svg} /><figcaption>{v.svgCaption}</figcaption></figure>

    {v.sections.map((s) => (<><h2>{s.h}</h2>{s.body.map((p) => <p set:html={p} />)}</>))}

    <h2>他のバリエーション</h2>
    <ul>{others.map((x) => <li><a href={`/variants/${x.slug}/`}>{x.name}</a></li>)}</ul>

    <h2>基本の数独で遊ぶ</h2>
    <ul>
      <li><a href="/play/beginner/">初級</a> / <a href="/play/intermediate/">中級</a> / <a href="/play/advanced/">上級</a></li>
      <li><a href="/guide/how-to-solve/">解き方ガイド</a></li>
    </ul>

    <h2>よくある質問</h2>
    <dl class="faq">{v.faq.map((f) => (<><dt>{f.q}</dt><dd set:html={f.a} /></>))}</dl>
  </div>

  <style is:global>
    .px-text { max-width: 1060px; margin: 0 auto; }
    .crumb { font-size: 12px; color: var(--ink-3); margin-bottom: 10px; } .crumb a { color: var(--ink-3); text-decoration: none; }
    .lead { color: var(--ink-3); font-size: 14px; margin: 0 0 16px; }
    .upd { color: var(--ink-4); font-size: 12px; margin: -4px 0 10px; }
    main ul { line-height: 2; } main ul a, main p a { color: var(--accent); }
    .faq dt { font-family: var(--font-mincho); font-weight: 600; margin-top: 16px; } .faq dd { margin: 5px 0 0; color: var(--ink-3); }
    .var-fig { margin: 16px auto; text-align: center; max-width: 360px; }
    .var-fig svg { width: 100%; background: var(--surface); border: 1px solid var(--line); border-radius: 8px; padding: 8px; }
    .var-fig figcaption { font-size: 12px; color: var(--ink-3); margin-top: 6px; }
    @media (max-width: 760px) {
      .px-text { padding: 0; }
      .crumb { display: none; }
      .px-text h1 { font-size: var(--text-lg); margin: 0 0 8px; }
    }
  </style>
</Base>
