---
// 印刷工具本体:选难度+题数 → print.ts 从题库随机抽选 → window.print()。
// 被 print.astro(枢纽)与 print/[level].astro(难度专属落地页)共用。
// defaultLevel 是服务端初始选中难度(同时反映到 chip 的 .on 和 data-lv-default——
// print.ts 从 data-lv-default 读初始难度,?lv= 深链存在时以深链优先)。
import { LEVELS } from '../data/levels.ts';

interface Props {
  defaultLevel?: string;
}
const { defaultLevel = 'advanced' } = Astro.props;
---

<div id="print-tool" class="print-controls" data-lv-default={defaultLevel}>
  <div class="pc-row">
    <span class="pc-label">難易度</span>
    <div class="chips">
      {LEVELS.map((l) => <button type="button" class={l.slug === defaultLevel ? 'chip on' : 'chip'} data-lv={l.slug}>{l.ja}</button>)}
    </div>
  </div>
  <div class="pc-row">
    <span class="pc-label">問題数</span>
    <div class="chips">
      {[4, 6, 12].map((n) => <button type="button" class={n === 6 ? 'chip on' : 'chip'} data-ct={n}>{n}問</button>)}
    </div>
  </div>
  <label class="pc-check"><input type="checkbox" id="print-cand" /> 候補数字のマスを薄く印刷する</label>
  <button id="print-go" type="button" class="print-go">作成して印刷</button>
  <p id="print-status" class="print-status"></p>
  <p class="pc-solver"><a id="print-solver-link" href="/tools/solver/">印刷した問題の答え合わせは、写真で読み取る無料ソルバーへ →</a></p>
</div>

<div id="print-mount" class="print-mount"></div>

<script>
  import '../client/print.ts';
</script>

<style is:global>
  .print-controls { background: var(--surface); border: 1px solid var(--line); border-radius: 9px; padding: 18px; }
  .pc-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; flex-wrap: wrap; }
  .pc-label { font-size: 13px; color: var(--ink-3); min-width: 48px; }
  .chips { display: flex; gap: 6px; flex-wrap: wrap; }
  .chip { font-family: var(--font-mincho); font-size: 13px; padding: 5px 13px; border: 1px solid var(--line); border-radius: 4px; background: var(--bg); color: var(--ink); cursor: pointer; }
  .chip.on { background: var(--accent); color: var(--surface); border-color: var(--accent); }
  .pc-check { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--ink-3); margin: 4px 0 14px; }
  .print-go { background: var(--accent); color: var(--surface); border: 0; font-size: 14px; padding: 11px 22px; border-radius: 6px; cursor: pointer; font-family: var(--font-sans); }
  .print-status { font-size: 13px; color: var(--ink-3); margin: 10px 0 0; }
  .pc-solver { font-size: 13px; margin: 12px 0 0; } .pc-solver a { color: var(--accent); }

  .print-mount { margin-top: 20px; }
  .print-head { display: none; align-items: center; justify-content: space-between; margin-bottom: 12px; font-family: var(--font-mincho); }
  .ph-logo b { color: var(--accent); }
  .pz-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .pz figcaption, .az figcaption { font-family: var(--font-mincho); font-size: 12px; color: var(--ink-3); margin-bottom: 5px; }
  .pz svg, .az svg { width: 100%; border: 1px solid var(--line); }
  .answer-page { margin-top: 24px; }
  .answer-page h3 { font-family: var(--font-mincho); }
  .az-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }

  @media print {
    .snav, .sfoot, .fsh, .print-controls, .screen-only, .crumb, h1, .lead, .share-bar { display: none !important; }
    main { max-width: none; padding: 0; }
    body { background: #fff; }
    .print-head { display: flex; }
    .pz { page-break-inside: avoid; }
    .answer-page { page-break-before: always; }
    .pz svg, .az svg { border: 1px solid #ccc; }
  }
  @media (max-width: 560px) { .pz-grid { grid-template-columns: 1fr; } .az-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
