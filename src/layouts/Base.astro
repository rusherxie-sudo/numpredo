---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  wide?: boolean;
}
const { title, description, canonical, wide = false } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
// 内容长文（/guide/xxx・/variants/xxx）用 article；hub 索引页（/guide/）与其余（首页 / プレイ / ツール）用 website
const pathname = Astro.url.pathname;
const ogType =
  /^\/(guide|variants)\//.test(pathname) && pathname !== '/guide/' && pathname !== '/variants/'
    ? 'article'
    : 'website';

// フォントは非ブロッキング読み込み（LCP/CWV 対策）：preload で先取り → media="print" + onload で all に切替。
const fontHref =
  'https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@500;600;700&family=Noto+Sans+JP:wght@400;500;700&display=swap';

const footerCols = [
  {
    h: '遊ぶ',
    links: [
      ['初級（やさしい）', '/play/beginner/'],
      ['中級（ふつう）', '/play/intermediate/'],
      ['上級', '/play/advanced/'],
      ['難問', '/play/hard/'],
      ['超難問', '/play/extreme/'],
      ['キラー数独', '/variants/killer/'],
      ['6×6・不等号ほか', '/variants/6x6/'],
    ],
  },
  {
    h: '学ぶ・解き方',
    links: [
      ['解き方ガイド一覧', '/guide/'],
      ['解き方ガイド', '/guide/how-to-solve/'],
      ['ルール・遊び方', '/guide/rules/'],
      ['初心者のコツ', '/guide/beginner/'],
      ['上級テクニック', '/guide/advanced/'],
      ['数独とナンプレの違い', '/guide/sudoku-vs-numpre/'],
      ['数独の歴史', '/guide/sudoku-history/'],
      ['数独用語集', '/guide/glossary/'],
      ['数独と脳トレ', '/guide/brain-training/'],
    ],
  },
  {
    h: '問題集・印刷',
    links: [
      ['無料PDF問題集', '/print/'],
      ['毎日の問題', '/daily/'],
    ],
  },
  {
    h: 'ツール・その他',
    links: [
      ['数独ソルバー（解答）', '/tools/solver/'],
      ['新聞の数独の答え合わせ', '/guide/newspaper/'],
      ['毎日の数独', '/daily/'],
      ['このサイトについて', '/about/'],
    ],
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://numpredo.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="numpredo — 無料の数独・ナンプレ" />
    <meta property="og:site_name" content="numpredo" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://numpredo.com/og-image.png" />
    <meta name="twitter:image:alt" content="numpredo — 無料の数独・ナンプレ" />
    <meta name="robots" content="index,follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={fontHref} />
    <link rel="stylesheet" href={fontHref} media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href={fontHref} /></noscript>
    <slot name="head" />

    <!-- Google Analytics 4 — 经 Partytown 在 web worker 运行，不占主线程（保 CWV） -->
    <script type="text/partytown" is:inline src="https://www.googletagmanager.com/gtag/js?id=G-CM79TWN2J0"></script>
    <script type="text/partytown" is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-CM79TWN2J0');
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo">numpre<b>do</b></a>
      <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
      <label for="nav-toggle" class="burger" aria-label="メニュー"><span></span><span></span><span></span></label>
      <nav class="site-nav">
        <a href="/play/advanced/">遊ぶ</a>
        <a href="/guide/how-to-solve/">解き方</a>
        <a href="/print/">問題集</a>
        <a href="/daily/">毎日</a>
      </nav>
    </header>

    <main class={wide ? 'wide' : ''}><slot /></main>

    <footer class="site-footer">
      <div class="foot-cols">
        {
          footerCols.map((col) => (
            <div class="foot-col">
              <h4>{col.h}</h4>
              {col.links.map(([label, href]) => (
                <a href={href}>{label}</a>
              ))}
            </div>
          ))
        }
      </div>
      <div class="foot-friend">
        姉妹サイト：<a href="https://pazumori.com/" target="_blank" rel="noopener">パズモリ（パズル森）</a> — クロスワード・イラストロジック・ワードルなど、無料で遊べるオリジナルパズル
      </div>
      <div class="foot-bottom">
        <span class="foot-logo">numpre<b>do</b><span class="foot-tag">無料・登録不要</span></span>
        <span class="foot-links">
          <a href="/terms/">利用規約・免責</a>
          <a href="/privacy/">プライバシー</a>
          <a href="/contact/">お問い合わせ</a>
        </span>
      </div>
    </footer>

    <style is:global>
      :root {
        --washi: #f7f5f0; --card: #fffdf8; --sumi: #1f1b16; --sub: #6b6258; --line: #e4dece;
        --thick: #3a352e; --shu: #c8463c; --shuw: rgba(200, 70, 60, 0.13); --tofu: #f1ead9;
        --tofu2: #eadfc9; --ai: #2b5b7a; --err: #b5302a; --note: #a89f90;
        --min: 'Noto Serif JP', serif; --sans: 'Noto Sans JP', system-ui, -apple-system, sans-serif;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --washi: #1b1916; --card: #24211c; --sumi: #ece7dd; --sub: #9c9388; --line: #3a352e;
          --thick: #7a7060; --shu: #e0655a; --shuw: rgba(224, 101, 90, 0.17); --tofu: #2c2822;
          --tofu2: #363029; --ai: #86b6d2; --err: #e0655a; --note: #8a8174;
        }
      }
      * { box-sizing: border-box; }
      body { margin: 0; font-family: var(--sans); color: var(--sumi); background: var(--washi); line-height: 1.8; }
      a { color: inherit; }

      .site-header { position: relative; display: flex; align-items: center; justify-content: space-between; padding: 13px 22px; background: var(--card); border-bottom: 1px solid var(--line); }
      .logo { font-family: var(--min); font-weight: 600; font-size: 21px; letter-spacing: 0.03em; text-decoration: none; color: var(--sumi); }
      .logo b { color: var(--shu); font-weight: 600; }
      .site-nav { display: flex; gap: 18px; }
      .site-nav a { color: var(--sub); text-decoration: none; font-size: 14px; }
      .site-nav a:hover { color: var(--shu); }
      .burger { display: none; flex-direction: column; gap: 4px; cursor: pointer; padding: 4px; }
      .burger span { width: 20px; height: 2px; background: var(--sumi); display: block; }

      main { max-width: 1060px; margin: 0 auto; padding: 26px 24px 48px; }
      h1 { font-family: var(--min); font-weight: 600; font-size: 23px; line-height: 1.45; }
      h2 { font-family: var(--min); font-weight: 600; font-size: 19px; margin-top: 34px; padding-left: 12px; border-left: 3px solid var(--shu); }
      p { font-size: 15px; }

      .site-footer { background: var(--card); border-top: 1px solid var(--line); padding: 26px 22px 16px; }
      .foot-cols { max-width: 1060px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
      .foot-col h4 { font-family: var(--min); font-weight: 600; font-size: 13px; margin: 0 0 9px; padding-left: 8px; border-left: 2px solid var(--shu); }
      .foot-col a { display: block; font-size: 12.5px; color: var(--sub); text-decoration: none; padding: 3px 0; }
      .foot-col a:hover { color: var(--shu); }
      .foot-friend { max-width: 1060px; margin: 18px auto 0; padding-top: 14px; border-top: 1px solid var(--line); font-size: 12px; color: var(--sub); line-height: 1.7; }
      .foot-friend a { color: var(--ai); text-decoration: none; }
      .foot-friend a:hover { color: var(--shu); }
      .foot-bottom { max-width: 1060px; margin: 14px auto 0; padding-top: 14px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 11px; color: var(--sub); }
      .foot-logo { font-family: var(--min); font-size: 14px; }
      .foot-logo b { color: var(--shu); }
      .foot-tag { font-size: 10px; border: 1px solid var(--line); border-radius: 3px; padding: 1px 6px; margin-left: 8px; }
      .foot-links { display: flex; gap: 14px; }
      .foot-links a { color: var(--sub); text-decoration: none; }

      @media (max-width: 560px) {
        .burger { display: flex; }
        .site-nav { position: absolute; top: 100%; right: 0; left: 0; flex-direction: column; gap: 0; background: var(--card); border-bottom: 1px solid var(--line); max-height: 0; overflow: hidden; transition: max-height 0.2s ease; z-index: 20; }
        .nav-toggle:checked ~ .site-nav { max-height: 240px; }
        .site-nav a { padding: 12px 22px; border-top: 1px solid var(--line); font-size: 15px; }
        .foot-cols { grid-template-columns: repeat(2, 1fr); }
      }
    </style>
  </body>
</html>
