---
import '../styles/tokens.css';
import FloatingShare from '../components/FloatingShare.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  wide?: boolean;
}
const { title, description, canonical, wide = false } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
// 内容长文（/guide/xxx・/variants/xxx）用 article；hub 索引页（/guide/）与其余用 website
const pathname = Astro.url.pathname;
const ogType =
  /^\/(guide|variants)\//.test(pathname) && pathname !== '/guide/' && pathname !== '/variants/'
    ? 'article'
    : 'website';

// グローバルナビ（active はパス接頭辞で判定）
const nav: [string, string, string][] = [
  ['遊ぶ', '/play/beginner/', '/play'],
  ['解き方', '/guide/', '/guide'],
  ['印刷', '/print/', '/print'],
  ['デイリー', '/daily/', '/daily'],
  ['ソルバー', '/tools/solver/', '/tools/solver'],
];
const activePre = nav.find(([, , pre]) => pathname.startsWith(pre))?.[2] ?? '';

const footerCols = [
  {
    h: '遊ぶ',
    links: [
      ['初級（やさしい）', '/play/beginner/'],
      ['中級（ふつう）', '/play/intermediate/'],
      ['上級', '/play/advanced/'],
      ['難問', '/play/hard/'],
      ['超難問', '/play/extreme/'],
      ['キラー数独', '/variants/killer/'],
      ['6×6・不等号ほか', '/variants/6x6/'],
    ],
  },
  {
    h: '学ぶ・解き方',
    links: [
      ['解き方ガイド一覧', '/guide/'],
      ['解き方ガイド', '/guide/how-to-solve/'],
      ['ルール・遊び方', '/guide/rules/'],
      ['初心者のコツ', '/guide/beginner/'],
      ['子供向け・簡単な数独', '/guide/for-kids/'],
      ['上級テクニック', '/guide/advanced/'],
      ['数独とナンプレの違い', '/guide/sudoku-vs-numpre/'],
      ['数独の歴史', '/guide/sudoku-history/'],
      ['数独用語集', '/guide/glossary/'],
      ['数独と脳トレ', '/guide/brain-training/'],
    ],
  },
  {
    h: '問題集・印刷',
    links: [
      ['無料PDF問題集', '/print/'],
      ['毎日の問題', '/daily/'],
    ],
  },
  {
    h: 'ツール・その他',
    links: [
      ['数独ソルバー（解答）', '/tools/solver/'],
      ['新聞の数独の答え合わせ', '/guide/newspaper/'],
      ['毎日の数独', '/daily/'],
      ['このサイトについて', '/about/'],
    ],
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- 防闪：本文渲染前に data-theme を確定（localStorage 優先、無ければ OS 設定） -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('numpredo_theme');
          if (t !== 'light' && t !== 'dark')
            t = window.matchMedia && matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content="https://numpredo.com/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="numpredo — 無料の数独・ナンプレ" />
    <meta property="og:site_name" content="numpredo" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://numpredo.com/og-image.png" />
    <meta name="twitter:image:alt" content="numpredo — 無料の数独・ナンプレ" />
    <meta name="robots" content="index,follow" />
    <slot name="head" />

    <!-- Google Analytics 4 — 经 Partytown 在 web worker 运行，不占主线程（保 CWV） -->
    <script type="text/partytown" is:inline src="https://www.googletagmanager.com/gtag/js?id=G-CM79TWN2J0"></script>
    <script type="text/partytown" is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-CM79TWN2J0');
    </script>
  </head>
  <body>
    <header class="snav">
      <div class="snav-in">
        <a href="/" class="snav-logo">numpre<b>do</b></a>
        <nav class="snav-links" data-desk>
          {nav.map(([label, href, pre]) => <a href={href} class={activePre === pre ? 'on' : ''}>{label}</a>)}
        </nav>
        <div class="snav-tools">
          <button class="snav-theme" data-theme-toggle aria-label="テーマ切替">☾</button>
          <a href="/play/beginner/" class="snav-cta" data-cta>今すぐ遊ぶ</a>
          <button class="snav-burger" data-burger aria-label="メニュー" aria-expanded="false">☰</button>
        </div>
      </div>
      <nav class="snav-mobile" data-mobile hidden>
        {nav.map(([label, href]) => <a href={href}>{label}</a>)}
        <a href="/play/beginner/" class="snav-mcta">今すぐ遊ぶ</a>
      </nav>
    </header>

    <main class={wide ? 'wide' : ''}><slot /></main>

    <footer class="sfoot">
      <div class="sfoot-cols">
        {
          footerCols.map((col) => (
            <div class="sfoot-col">
              <h4>{col.h}</h4>
              {col.links.map(([label, href]) => (
                <a href={href}>{label}</a>
              ))}
            </div>
          ))
        }
      </div>
      <div class="sfoot-friend">
        姉妹サイト：<a href="https://pazumori.com/" target="_blank" rel="noopener">パズモリ（パズル森）</a> — クロスワード・イラストロジック・ワードルなど、無料で遊べるオリジナルパズル
      </div>
      <div class="sfoot-bottom">
        <span class="sfoot-logo">numpre<b>do</b><span class="sfoot-tag">無料・登録不要</span></span>
        <span class="sfoot-links">
          <a href="/terms/">利用規約・免責</a>
          <a href="/privacy/">プライバシー</a>
          <a href="/contact/">お問い合わせ</a>
        </span>
      </div>
    </footer>

    <FloatingShare />

    <script>
      import '../client/site-nav.ts';
    </script>

    <style is:global>
      * { box-sizing: border-box; }
      body {
        margin: 0; font-family: var(--font-sans); color: var(--ink); background: var(--bg);
        line-height: 1.8; transition: background-color .25s ease, color .25s ease;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); }
      h1, h2, h3 { color: var(--ink); }
      h1 { font-weight: 700; font-size: var(--text-2xl); line-height: 1.3; letter-spacing: .01em; }
      h2 { font-weight: 700; font-size: var(--text-xl); line-height: 1.4; margin-top: var(--space-6); }
      h3 { font-weight: 700; font-size: var(--text-md); }
      p { font-size: var(--text-base); }

      main { max-width: 1080px; margin: 0 auto; padding: var(--space-5) var(--space-5) var(--space-8); }
      main.wide { max-width: 1240px; }

      /* ---------- SiteNav ---------- */
      .snav { position: sticky; top: 0; z-index: 30; background: var(--surface); border-bottom: 1px solid var(--line); }
      .snav-in { max-width: 1240px; margin: 0 auto; height: 60px; padding: 0 var(--space-5); display: flex; align-items: center; gap: var(--space-5); }
      .snav-logo { font-family: var(--font-mincho); font-weight: 700; font-size: 23px; letter-spacing: .01em; text-decoration: none; color: var(--ink); }
      .snav-logo b { color: var(--accent); font-weight: 700; }
      .snav-links { display: flex; gap: var(--space-5); margin-right: auto; }
      .snav-links a { color: var(--ink-2); text-decoration: none; font-size: var(--text-base); font-weight: 500; padding: 4px 0; transition: color .15s; }
      .snav-links a:hover { color: var(--accent); }
      .snav-links a.on { color: var(--accent); font-weight: 700; }
      .snav-tools { display: flex; align-items: center; gap: var(--space-3); }
      .snav-theme { background: none; border: 1px solid var(--line); color: var(--ink-2); width: 36px; height: 36px; border-radius: var(--radius-pill); cursor: pointer; font-size: 15px; line-height: 1; display: flex; align-items: center; justify-content: center; }
      .snav-theme:hover { border-color: var(--accent); color: var(--accent); }
      .snav-cta { background: var(--accent); color: var(--accent-on); text-decoration: none; font-size: var(--text-sm); font-weight: 700; padding: 9px 18px; border-radius: var(--radius-pill); white-space: nowrap; }
      .snav-cta:hover { background: var(--accent-ink); }
      .snav-burger { display: none; background: none; border: 0; color: var(--ink); font-size: 22px; line-height: 1; cursor: pointer; padding: 4px 6px; }
      .snav-mobile { display: none; }

      /* ---------- SiteFooter ---------- */
      .sfoot { background: var(--surface); border-top: 1px solid var(--line); padding: var(--space-8) var(--space-5) var(--space-5); margin-top: var(--space-10); }
      .sfoot-cols { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--space-5); }
      .sfoot-col h4 { font-weight: 700; font-size: var(--text-sm); margin: 0 0 var(--space-3); color: var(--ink); }
      .sfoot-col a { display: block; font-size: var(--text-sm); color: var(--ink-3); text-decoration: none; padding: 4px 0; }
      .sfoot-col a:hover { color: var(--accent); }
      .sfoot-friend { max-width: 1080px; margin: var(--space-5) auto 0; padding-top: var(--space-4); border-top: 1px solid var(--line); font-size: var(--text-xs); color: var(--ink-3); line-height: 1.7; }
      .sfoot-friend a { color: var(--accent); text-decoration: none; }
      .sfoot-bottom { max-width: 1080px; margin: var(--space-4) auto 0; padding-top: var(--space-4); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--space-2); font-size: var(--text-xs); color: var(--ink-3); }
      .sfoot-logo { font-family: var(--font-mincho); font-size: var(--text-md); font-weight: 700; }
      .sfoot-logo b { color: var(--accent); }
      .sfoot-tag { font-size: 10px; border: 1px solid var(--line); border-radius: var(--radius-sm); padding: 1px 7px; margin-left: var(--space-2); font-family: var(--font-sans); }
      .sfoot-links { display: flex; gap: var(--space-4); }
      .sfoot-links a { color: var(--ink-3); text-decoration: none; }
      .sfoot-links a:hover { color: var(--accent); }

      @media (max-width: 760px) {
        .snav-links[data-desk] { display: none; }
        .snav-cta[data-cta] { display: none; }
        .snav-burger { display: flex; }
        .snav-tools { margin-left: auto; }
        .snav-mobile { display: flex; flex-direction: column; padding: var(--space-3) var(--space-5) var(--space-5); background: var(--surface); border-top: 1px solid var(--line); }
        .snav-mobile[hidden] { display: none; }
        .snav-mobile a { color: var(--ink); text-decoration: none; font-size: var(--text-md); font-weight: 500; padding: var(--space-3) 0; border-bottom: 1px solid var(--line); }
        .snav-mcta { color: var(--accent) !important; font-weight: 700 !important; border-bottom: 0 !important; }
      }
    </style>
  </body>
</html>
